---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import StickyBar from '../components/StickyBar.astro';
import content from '../data/content.json';
import { pick, isRTL, LOCALES } from '../lib/i18n.js';
const { lang } = Astro.props;
const dir = isRTL(lang) ? 'rtl' : 'ltr';
const logo = content.brand.logo || '/images/logo.jpg';
const brandName = content.brand.name;
const instagram = content.contacts.instagram || '#';

const navLinks = [
  { href: '#hair',     label: pick({ ru: 'Прически', he: 'תספורות', en: 'Hair' }, lang) },
  { href: '#nails',    label: pick({ ru: 'Маникюр', he: 'מניקור', en: 'Nails' }, lang) },
  { href: '#skin',     label: pick({ ru: 'Косметология', he: 'קוסמטיקה', en: 'Skin' }, lang) },
  { href: '#masters',  label: pick({ ru: 'Мастера', he: 'צוות', en: 'Team' }, lang) },
  { href: '#contacts', label: pick({ ru: 'Контакты', he: 'צור קשר', en: 'Contact' }, lang) },
];

const bookLabel = pick({ ru: 'Записаться', he: 'קביעת תור', en: 'Book' }, lang);
const soonLabel = pick({
  ru: 'Онлайн-запись скоро заработает ♥',
  he: 'קביעת תור אונליין בקרוב ♥',
  en: 'Online booking coming soon ♥'
}, lang);
---
<html lang={lang} dir={dir}>
  <SeoHead lang={lang} />
  <body>

    <!-- ШАПКА -->
    <header class="site-header" id="site-header">
      <div class="header-top">
        <!-- Лого -->
        <a class="brand" href={`/${lang}/`}>
          <div class="brand-logo-wrap">
            <img class="brand-logo" src={logo} alt={brandName} />
          </div>
          <span class="brand-name">{brandName}</span>
        </a>

        <!-- Действия -->
        <div class="header-actions">
          <!-- Кнопка записи (пока неактивна) -->
          <button class="header-book-btn" type="button" id="header-book-btn" aria-label={bookLabel}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {bookLabel}
          </button>

          <!-- Instagram -->
          <a class="header-insta" href={instagram} target="_blank" rel="noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>

          <!-- Бургер -->
          <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
            <span class="hb-line"></span>
            <span class="hb-line"></span>
            <span class="hb-line"></span>
          </button>
        </div>
      </div>

      <!-- Выбор языка -->
      <div class="header-langs">
        {LOCALES.map(l => (
          <a href={`/${l}/`} class={`lang-btn${l === lang ? ' lang-active' : ''}`}>{l.toUpperCase()}</a>
        ))}
      </div>
    </header>

    <!-- Глобальный граффити фон -->
    <div class="graffiti-bg" aria-hidden="true">
      <span class="grf" style="top:6%;left:3%;font-size:3.8rem;opacity:0.20;animation-delay:0s;animation-duration:9s">♥</span>
      <span class="grf" style="top:15%;right:5%;font-size:2.6rem;opacity:0.18;animation-delay:1.3s;animation-duration:11s">♥</span>
      <span class="grf" style="top:28%;left:7%;font-size:5rem;opacity:0.14;animation-delay:0.7s;animation-duration:10s">♥</span>
      <span class="grf" style="top:22%;right:2%;font-size:2.2rem;opacity:0.22;animation-delay:2.1s;animation-duration:8s">✕</span>
      <span class="grf" style="top:42%;left:1%;font-size:3.2rem;opacity:0.16;animation-delay:0.4s;animation-duration:12s">♥</span>
      <span class="grf" style="top:50%;right:7%;font-size:4.2rem;opacity:0.19;animation-delay:1.8s;animation-duration:9s">♥</span>
      <span class="grf" style="top:60%;left:5%;font-size:2.8rem;opacity:0.15;animation-delay:3.0s;animation-duration:11s">✕</span>
      <span class="grf" style="top:68%;right:3%;font-size:3.6rem;opacity:0.20;animation-delay:0.9s;animation-duration:10s">♥</span>
      <span class="grf" style="top:78%;left:3%;font-size:2.4rem;opacity:0.17;animation-delay:2.4s;animation-duration:8s">♥</span>
      <span class="grf" style="top:85%;right:8%;font-size:4.5rem;opacity:0.14;animation-delay:1.1s;animation-duration:13s">♥</span>
      <span class="grf" style="top:35%;left:48%;font-size:2rem;opacity:0.12;animation-delay:1.6s;animation-duration:10s">♥</span>
      <span class="grf" style="top:72%;left:42%;font-size:3rem;opacity:0.13;animation-delay:0.5s;animation-duration:12s">✕</span>
    </div>

    <!-- Overlay для закрытия меню -->
    <div class="nav-overlay" id="nav-overlay"></div>

    <!-- Dropdown навигация -->
    <nav class="nav-dropdown" id="nav-dropdown" aria-label="Navigation">
      <button class="nav-close-btn" id="nav-close" aria-label="Close menu">✕</button>
      {navLinks.map(item => (
        <a class="nav-link" href={item.href}>
          <span class="nav-heart">♥</span>{item.label}
        </a>
      ))}
    </nav>

    <!-- Контент -->
    <main><slot /></main>

    <!-- Футер -->
    <footer class="site-footer">
      <div class="container">
        <span class="footer-brand-name">{brandName}</span>
        <p class="footer-city">{pick(content.salon.city, lang)}</p>
        <div class="footer-hearts">♥ ♥ ♥</div>
        <p class="footer-rights">&copy; {new Date().getFullYear()} {brandName}</p>
      </div>
    </footer>

    <StickyBar lang={lang} />

    <!-- Попап "скоро" для кнопки записи -->
    <div class="booking-overlay" id="booking-soon" role="dialog" aria-modal="true">
      <div class="booking-box" style="position:relative;">
        <button class="booking-close" id="booking-close" aria-label="Close">✕</button>
        <div style="font-size:2.5rem;margin-bottom:12px;">💋</div>
        <h3>{pick({ ru: 'Совсем скоро', he: 'בקרוב', en: 'Coming Soon' }, lang)}</h3>
        <p>{soonLabel}</p>
        <a
          class="btn btn-whatsapp"
          href={`https://wa.me/${(content.contacts.whatsapp || '').replace(/\D/g,'')}`}
          target="_blank" rel="noreferrer"
          style="width:100%;justify-content:center;"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:16px;height:16px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>

    <script is:inline>
      (function() {
        var hamburger = document.getElementById('hamburger');
        var dropdown  = document.getElementById('nav-dropdown');
        var overlay   = document.getElementById('nav-overlay');
        var closeBtn  = document.getElementById('nav-close');
        var header    = document.getElementById('site-header');
        var bookBtn   = document.getElementById('header-book-btn');
        var bookingSoon   = document.getElementById('booking-soon');
        var bookingClose  = document.getElementById('booking-close');

        function openNav() {
          dropdown && dropdown.classList.add('nav-open');
          overlay  && overlay.classList.add('nav-open');
          hamburger && hamburger.classList.add('hb-open');
          hamburger && hamburger.setAttribute('aria-expanded','true');
        }
        function closeNav() {
          dropdown && dropdown.classList.remove('nav-open');
          overlay  && overlay.classList.remove('nav-open');
          hamburger && hamburger.classList.remove('hb-open');
          hamburger && hamburger.setAttribute('aria-expanded','false');
        }

        hamburger && hamburger.addEventListener('click', function() {
          dropdown && dropdown.classList.contains('nav-open') ? closeNav() : openNav();
        });
        closeBtn && closeBtn.addEventListener('click', closeNav);
        overlay  && overlay.addEventListener('click', closeNav);
        dropdown && dropdown.querySelectorAll('a').forEach(function(a) {
          a.addEventListener('click', closeNav);
        });

        // Header scroll
        window.addEventListener('scroll', function() {
          header && header.classList.toggle('scrolled', window.scrollY > 50);
        }, { passive: true });

        // Booking soon popup
        if (bookBtn && bookingSoon) {
          bookBtn.addEventListener('click', function() {
            bookingSoon.classList.add('is-open');
          });
          bookingSoon.addEventListener('click', function(e) {
            if (e.target === bookingSoon) bookingSoon.classList.remove('is-open');
          });
          bookingClose && bookingClose.addEventListener('click', function() {
            bookingSoon.classList.remove('is-open');
          });
        }
      })();
    </script>

    <style>
      .nav-close-btn {
        position: absolute; top: 20px; inset-inline-end: 20px;
        background: rgba(255,133,194,0.08); border: 1px solid var(--line);
        color: var(--ink-mute); font-size: 1rem; width: 32px; height: 32px;
        border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: background 0.2s;
      }
      .nav-close-btn:hover { background: rgba(255,133,194,0.16); color: var(--ink); }
    </style>
  </body>
</html>
