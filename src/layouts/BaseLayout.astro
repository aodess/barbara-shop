---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import StickyBar from '../components/StickyBar.astro';
import content from '../data/content.json';
import { pick, isRTL, LOCALES } from '../lib/i18n.js';
const { lang } = Astro.props;
const dir = isRTL(lang) ? 'rtl' : 'ltr';
const logo = content.brand.logo || '/images/logo.jpg';
const brandName = content.brand.name;
const instagram = content.contacts.instagram || '#';

const navLinks = [
  { href: '#hair',     label: pick({ ru: 'Прически', he: 'תספורות', en: 'Hair' }, lang) },
  { href: '#nails',    label: pick({ ru: 'Маникюр', he: 'מניקור', en: 'Nails' }, lang) },
  { href: '#skin',     label: pick({ ru: 'Косметология', he: 'קוסמטיקה', en: 'Skin' }, lang) },
  { href: '#masters',  label: pick({ ru: 'Мастера', he: 'צוות', en: 'Team' }, lang) },
  { href: '#contacts', label: pick({ ru: 'Контакты', he: 'צור קשר', en: 'Contact' }, lang) },
];

const bookLabel = pick({ ru: 'Записаться', he: 'קביעת תור', en: 'Book' }, lang);
const soonLabel = pick({
  ru: 'Онлайн-запись скоро заработает ♥',
  he: 'קביעת תור אונליין בקרוב ♥',
  en: 'Online booking coming soon ♥'
}, lang);
---
<html lang={lang} dir={dir}>
  <SeoHead lang={lang} />
  <body>

    <!-- ШАПКА -->
    <header class="site-header" id="site-header">
      <div class="header-shapka-bg" aria-hidden="true">
        <img src="/images/shapka.webp" alt="" />
      </div>
      <div class="header-top">
        <!-- Лого -->
        <a class="brand" href={`/${lang}/`}>
          <div class="brand-logo-wrap">
            <img class="brand-logo" src={logo} alt={brandName} />
          </div>
          <span class="brand-text">
            <span class="brand-name">{brandName}</span>
            <span class="brand-tagline">
              {pick({ ru: 'Салон красоты · Петах-Тиква', he: 'סלון יופי · פתח תקווה', en: 'Beauty Salon · Petah Tikva' }, lang)}
            </span>
          </span>
        </a>

        <!-- Действия: языки над иконкой инсты -->
        <div class="header-actions">
          <div class="header-langs-inline">
            {LOCALES.map(l => (
              <a href={`/${l}/`} class={`lang-btn${l === lang ? ' lang-active' : ''}`}>{l.toUpperCase()}</a>
            ))}
          </div>

          <a class="header-insta" href={instagram} target="_blank" rel="noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <!-- Плавающая кнопка меню — всегда видна при прокрутке -->
    <button class="floating-menu" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span class="hb-line"></span>
      <span class="hb-line"></span>
      <span class="hb-line"></span>
    </button>

    <!-- Глобальный граффити фон — BARBIE PINK -->
    <div class="graffiti-bg" aria-hidden="true">
      <span class="grf" style="top:5%;left:2%;font-size:4.5rem;opacity:0.45;animation-delay:0s;animation-duration:9s">♥</span>
      <span class="grf" style="top:14%;right:4%;font-size:3.2rem;opacity:0.42;animation-delay:1.3s;animation-duration:11s">♥</span>
      <span class="grf" style="top:26%;left:5%;font-size:6rem;opacity:0.32;animation-delay:0.7s;animation-duration:10s">♥</span>
      <span class="grf" style="top:20%;right:2%;font-size:2.8rem;opacity:0.50;animation-delay:2.1s;animation-duration:8s;font-style:italic">x</span>
      <span class="grf" style="top:40%;left:1%;font-size:3.8rem;opacity:0.38;animation-delay:0.4s;animation-duration:12s">♥</span>
      <span class="grf" style="top:48%;right:6%;font-size:5rem;opacity:0.40;animation-delay:1.8s;animation-duration:9s">♥</span>
      <span class="grf" style="top:58%;left:4%;font-size:3.2rem;opacity:0.42;animation-delay:3.0s;animation-duration:11s;font-style:italic">x</span>
      <span class="grf" style="top:66%;right:2%;font-size:4.2rem;opacity:0.45;animation-delay:0.9s;animation-duration:10s">♥</span>
      <span class="grf" style="top:76%;left:2%;font-size:3rem;opacity:0.40;animation-delay:2.4s;animation-duration:8s">♥</span>
      <span class="grf" style="top:83%;right:7%;font-size:5.5rem;opacity:0.35;animation-delay:1.1s;animation-duration:13s">♥</span>
      <span class="grf" style="top:33%;left:47%;font-size:2.5rem;opacity:0.38;animation-delay:1.6s;animation-duration:10s">♥</span>
      <span class="grf" style="top:70%;left:41%;font-size:3.5rem;opacity:0.35;animation-delay:0.5s;animation-duration:12s;font-style:italic">x</span>
      <span class="grf" style="top:10%;left:40%;font-size:2.2rem;opacity:0.42;animation-delay:2.8s;animation-duration:9s">♥</span>
      <span class="grf" style="top:90%;left:25%;font-size:4rem;opacity:0.38;animation-delay:1.4s;animation-duration:11s">♥</span>
    </div>

    <!-- Overlay для закрытия меню -->
    <div class="nav-overlay" id="nav-overlay"></div>

    <!-- Dropdown навигация -->
    <nav class="nav-dropdown" id="nav-dropdown" aria-label="Navigation">
      <button class="nav-close-btn" id="nav-close" aria-label="Close menu">✕</button>
      <button class="nav-link nav-home" id="nav-home" type="button">
        <span class="nav-heart">⌂</span>{pick({ ru: 'На главную', he: 'לראש הדף', en: 'To top' }, lang)}
      </button>
      {navLinks.map(item => (
        <a class="nav-link" href={item.href}>
          <span class="nav-heart">♥</span>{item.label}
        </a>
      ))}
    </nav>

    <!-- Контент -->
    <main class="site-main"><slot /></main>

    <!-- Футер -->
    <footer class="site-footer">
      <div class="container">
        <span class="footer-brand-name">{brandName}</span>
        <p class="footer-city">{pick(content.salon.city, lang)}</p>
        <div class="footer-hearts">♥ ♥ ♥</div>
        <p class="footer-rights">&copy; {new Date().getFullYear()} {brandName}</p>
      </div>
    </footer>

    <StickyBar lang={lang} />

    <!-- Попап "скоро" для кнопки записи -->
    <div class="booking-overlay" id="booking-soon" role="dialog" aria-modal="true">
      <div class="booking-box" style="position:relative;">
        <button class="booking-close" id="booking-close" aria-label="Close">✕</button>
        <div style="font-size:2.5rem;margin-bottom:12px;color:var(--rose-bright);text-shadow:0 0 24px rgba(255,133,194,0.7);">♥</div>
        <h3>{pick({ ru: 'Совсем скоро', he: 'בקרוב', en: 'Coming Soon' }, lang)}</h3>
        <p>{soonLabel}</p>
        <a
          class="btn btn-whatsapp"
          href={`https://wa.me/${(content.contacts.whatsapp || '').replace(/\D/g,'')}`}
          target="_blank" rel="noreferrer"
          style="width:100%;justify-content:center;"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:16px;height:16px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>

    <script is:inline>
      (function() {
        var hamburger = document.getElementById('hamburger');
        var dropdown  = document.getElementById('nav-dropdown');
        var overlay   = document.getElementById('nav-overlay');
        var closeBtn  = document.getElementById('nav-close');
        var header    = document.getElementById('site-header');
        var bookBtn   = document.getElementById('header-book-btn');
        var bookingSoon   = document.getElementById('booking-soon');
        var bookingClose  = document.getElementById('booking-close');

        function openNav() {
          dropdown && dropdown.classList.add('nav-open');
          overlay  && overlay.classList.add('nav-open');
          hamburger && hamburger.classList.add('hb-open');
          hamburger && hamburger.setAttribute('aria-expanded','true');
        }
        function closeNav() {
          dropdown && dropdown.classList.remove('nav-open');
          overlay  && overlay.classList.remove('nav-open');
          hamburger && hamburger.classList.remove('hb-open');
          hamburger && hamburger.setAttribute('aria-expanded','false');
        }

        hamburger && hamburger.addEventListener('click', function() {
          dropdown && dropdown.classList.contains('nav-open') ? closeNav() : openNav();
        });
        closeBtn && closeBtn.addEventListener('click', closeNav);
        overlay  && overlay.addEventListener('click', closeNav);
        dropdown && dropdown.querySelectorAll('a').forEach(function(a) {
          a.addEventListener('click', closeNav);
        });

        // Кнопка "На главную" — скролл наверх
        var navHome = document.getElementById('nav-home');
        navHome && navHome.addEventListener('click', function() {
          closeNav();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // Header scroll
        window.addEventListener('scroll', function() {
          header && header.classList.toggle('scrolled', window.scrollY > 50);
        }, { passive: true });

        // Booking soon popup
        if (bookBtn && bookingSoon) {
          bookBtn.addEventListener('click', function() {
            bookingSoon.classList.add('is-open');
          });
          bookingSoon.addEventListener('click', function(e) {
            if (e.target === bookingSoon) bookingSoon.classList.remove('is-open');
          });
          bookingClose && bookingClose.addEventListener('click', function() {
            bookingSoon.classList.remove('is-open');
          });
        }
      })();
    </script>

    <!-- GSAP ScrollTrigger анимации -->
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      gsap.registerPlugin(ScrollTrigger);

      // Анимация секций при скролле
      gsap.utils.toArray('section').forEach(function(sec) {
        var head = sec.querySelector('.section-head');
        if (head) {
          gsap.fromTo(head,
            { opacity: 0, y: 40 },
            { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out',
              scrollTrigger: { trigger: sec, start: 'top 80%', once: true }
            }
          );
        }
        // Карточки с задержкой
        var cards = sec.querySelectorAll('.price-card, .master-card, .ns-item');
        if (cards.length) {
          gsap.fromTo(cards,
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
              stagger: 0.12,
              scrollTrigger: { trigger: sec, start: 'top 75%', once: true }
            }
          );
        }
      });

      // Hero параллакс
      var heroBg = document.querySelector('.hero');
      if (heroBg) {
        gsap.to('.hero-graffiti .hg', {
          yPercent: -25, ease: 'none',
          scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1.5 }
        });
      }
    </script>

    <!-- Cursor sparkle — только desktop -->
    <script is:inline>
      (function() {
        if (!window.matchMedia('(pointer: fine)').matches) return;
        var lastT = 0;
        document.addEventListener('mousemove', function(e) {
          var now = Date.now();
          if (now - lastT < 90) return;
          lastT = now;
          var el = document.createElement('span');
          var sz = Math.random() * 14 + 8;
          el.textContent = '♥';
          el.style.cssText = 'position:fixed;left:'+e.clientX+'px;top:'+e.clientY+'px;'
            +'pointer-events:none;z-index:9999;font-size:'+sz+'px;'
            +'color:#FF1493;text-shadow:0 0 8px rgba(255,20,147,.9);'
            +'transform:translate(-50%,-50%);'
            +'animation:cursorHeart .9s ease-out forwards;';
          document.body.appendChild(el);
          setTimeout(function(){ el.parentNode && el.parentNode.removeChild(el); }, 900);
        });
      })();
    </script>

    <style>
      .nav-close-btn {
        position: absolute; top: 20px; inset-inline-end: 20px;
        background: rgba(255,133,194,0.08); border: 1px solid var(--line);
        color: var(--ink-mute); font-size: 1rem; width: 32px; height: 32px;
        border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: background 0.2s;
      }
      .nav-close-btn:hover { background: rgba(255,133,194,0.16); color: var(--ink); }
    </style>
  </body>
</html>
