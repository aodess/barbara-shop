---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import StickyBar from '../components/StickyBar.astro';
import Booking from '../components/Booking.astro';
import content from '../data/content.json';
import { pick, isRTL, LOCALES } from '../lib/i18n.js';
const { lang } = Astro.props;
const dir = isRTL(lang) ? 'rtl' : 'ltr';
const logo = content.brand.logo || '/images/logo.jpg';
const brandName = content.brand.name;
const whatsapp = content.contacts.whatsapp || '+972501234567';

const navLinks = [
  { href: '#services', ru: 'Услуги',   he: 'שירותים', en: 'Services' },
  { href: '#gallery',  ru: 'Работы',   he: 'עבודות',  en: 'Gallery'  },
  { href: '#masters',  ru: 'Мастера',  he: 'צוות',    en: 'Team'     },
  { href: '#menu',     ru: 'Цены',     he: 'תפריט',   en: 'Prices'   },
  { href: '#contacts', ru: 'Контакты', he: 'צור קשר', en: 'Contact'  },
];
---
<html lang={lang} dir={dir}>
  <SeoHead lang={lang} />
  <body>
    <header class="site-header" id="site-header">
      <div class="container header-inner">

        <a class="brand" href={`/${lang}/`}>
          <div class="brand-logo-ring">
            <img class="brand-logo" src={logo} alt={brandName} />
          </div>
          <div class="brand-text">
            <span class="brand-name">{brandName}</span>
            <span class="brand-sub">{pick({ ru: 'Салон красоты', he: 'סלון יופי', en: 'Beauty Salon' }, lang)}</span>
          </div>
        </a>

        <nav class="site-nav" id="site-nav" aria-label="Main navigation">
          {navLinks.map(item => (
            <a class="nav-link" href={item.href}>{pick(item, lang)}</a>
          ))}
        </nav>

        <div class="header-end">
          <div class="lang-switcher" role="navigation" aria-label="Language">
            {LOCALES.map(l => (
              <a href={`/${l}/`} class={`lang-btn${l === lang ? ' lang-active' : ''}`} aria-current={l === lang ? 'page' : undefined}>{l.toUpperCase()}</a>
            ))}
          </div>
          <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
            <span class="hb-line"></span>
            <span class="hb-line"></span>
            <span class="hb-line"></span>
          </button>
        </div>

      </div>
    </header>

    <main><slot /></main>

    <footer class="site-footer">
      <div class="footer-glow"></div>
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand-col">
            <a class="footer-brand-link" href={`/${lang}/`}>
              <img class="footer-logo" src={logo} alt={brandName} />
              <span class="footer-brand-name">{brandName}</span>
            </a>
            <p class="footer-tagline">{pick(content.brand.tagline, lang)}</p>
          </div>

          <nav class="footer-nav" aria-label="Footer navigation">
            {navLinks.map(item => (
              <a class="footer-nav-link" href={item.href}>{pick(item, lang)}</a>
            ))}
          </nav>

          <div class="footer-cta-col">
            <a class="btn btn-rose" href={`https://wa.me/${whatsapp.replace(/\D/g,'')}`} target="_blank" rel="noreferrer">
              <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <div class="footer-langs">
              {LOCALES.map(l => (
                <a href={`/${l}/`} class={`lang-btn${l === lang ? ' lang-active' : ''}`}>{l.toUpperCase()}</a>
              ))}
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          <p class="footer-rights">&copy; {new Date().getFullYear()} {brandName}. {pick({ ru: 'Все права защищены.', he: 'כל הזכויות שמורות.', en: 'All rights reserved.' }, lang)}</p>
          <p class="footer-city">{pick(content.salon.address, lang)}</p>
        </div>
      </div>
    </footer>

    <StickyBar lang={lang} />
    <Booking lang={lang} />

    <script is:inline>
      (function() {
        var hamburger = document.getElementById('hamburger');
        var nav = document.getElementById('site-nav');
        var header = document.getElementById('site-header');
        if (hamburger && nav) {
          hamburger.addEventListener('click', function() {
            var isOpen = nav.classList.toggle('nav-open');
            hamburger.classList.toggle('hb-open', isOpen);
            hamburger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          });
          nav.querySelectorAll('a').forEach(function(a) {
            a.addEventListener('click', function() {
              nav.classList.remove('nav-open');
              hamburger.classList.remove('hb-open');
              hamburger.setAttribute('aria-expanded', 'false');
            });
          });
        }
        window.addEventListener('scroll', function() {
          if (window.scrollY > 60) {
            header && header.classList.add('scrolled');
          } else {
            header && header.classList.remove('scrolled');
          }
        }, { passive: true });
      })();
    </script>
  </body>
</html>
