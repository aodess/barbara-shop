---
import content from '../data/content.json';
import { t } from '../lib/i18n.js';
const { lang } = Astro.props;
const tr = t(lang);
const photos = content.gallery.photos;
---
<section class="gallery" id="gallery">
  <div class="container">
    <div class="section-head gallery-head">
      <span class="eyebrow">{tr.gallery.eyebrow}</span>
      <h2>{tr.gallery.title}</h2>
      <p class="section-intro">{lang === 'ru' ? 'Живые результаты наших мастеров — натуральные, стойкие, безупречные.' : lang === 'he' ? 'תוצאות אמיתיות של המעצבות שלנו — טבעיות, עמידות, מושלמות.' : 'Real results from our artists — natural, lasting, flawless.'}</p>
    </div>

    <div class="splide gallery-splide" id="gallery-splide" aria-label={tr.gallery.title}>
      <div class="splide__track gallery-track">
        <ul class="splide__list">
          {photos.map((photo, idx) => (
            <li class="splide__slide gallery-slide">
              <div class="gallery-slide-inner" data-src={photo.src} data-idx={idx} role="button" tabindex="0" aria-label={photo.alt?.[lang] || ''}>
                <img src={photo.src} alt={photo.alt?.[lang] || ''} loading="lazy" />
                <div class="gallery-slide-overlay">
                  <span class="gallery-slide-zoom">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                  </span>
                  <span class="gallery-slide-label">{photo.alt?.[lang] || ''}</span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Лайтбокс -->
<div class="gallery-lightbox" id="gallery-lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
  <button class="gallery-lb-close" id="gallery-lb-close" aria-label="Close">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <button class="gallery-lb-prev" id="gallery-lb-prev" aria-label="Previous">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <div class="gallery-lb-img-wrap">
    <img id="gallery-lb-img" src="" alt="" />
  </div>
  <button class="gallery-lb-next" id="gallery-lb-next" aria-label="Next">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="gallery-lb-counter" id="gallery-lb-counter">1 / 7</div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Splide !== 'undefined' && document.getElementById('gallery-splide')) {
      new Splide('#gallery-splide', {
        type:         'loop',
        perPage:      3,
        perMove:      1,
        gap:          '1.5rem',
        autoplay:     true,
        interval:     4000,
        pauseOnHover: true,
        breakpoints: {
          900: { perPage: 2 },
          580: { perPage: 1 },
        },
      }).mount();
    }

    // Lightbox
    var photos = [];
    document.querySelectorAll('.gallery-slide-inner').forEach(function(el) {
      photos.push({ src: el.dataset.src, alt: el.querySelector('img').alt });
    });
    var lb = document.getElementById('gallery-lightbox');
    var lbImg = document.getElementById('gallery-lb-img');
    var lbCounter = document.getElementById('gallery-lb-counter');
    var cur = 0;

    function openLb(idx) {
      cur = ((idx % photos.length) + photos.length) % photos.length;
      lbImg.src = photos[cur].src;
      lbImg.alt = photos[cur].alt;
      if (lbCounter) lbCounter.textContent = (cur + 1) + ' / ' + photos.length;
      lb.classList.add('lb-open');
      document.body.style.overflow = 'hidden';
    }
    function closeLb() {
      lb.classList.remove('lb-open');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.gallery-slide-inner').forEach(function(el, i) {
      el.addEventListener('click', function() { openLb(i); });
      el.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') openLb(i); });
    });
    document.getElementById('gallery-lb-close').addEventListener('click', closeLb);
    document.getElementById('gallery-lb-prev').addEventListener('click', function() { openLb(cur - 1); });
    document.getElementById('gallery-lb-next').addEventListener('click', function() { openLb(cur + 1); });
    lb.addEventListener('click', function(e) { if (e.target === lb) closeLb(); });
    document.addEventListener('keydown', function(e) {
      if (!lb.classList.contains('lb-open')) return;
      if (e.key === 'Escape') closeLb();
      if (e.key === 'ArrowLeft') openLb(cur - 1);
      if (e.key === 'ArrowRight') openLb(cur + 1);
    });
  });
</script>

<style>
  .gallery-head { margin-bottom: 40px; }
  .gallery-head h2 { margin: 12px 0 16px; }
  .gallery-track { border-radius: 24px; overflow: visible; }
  .gallery-slide-inner {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: var(--surface-raised);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    cursor: pointer;
    outline: none;
  }
  .gallery-slide-inner:focus-visible { box-shadow: 0 0 0 3px var(--rose-bright), 0 8px 32px rgba(0,0,0,0.4); }
  .gallery-slide-inner img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }
  .gallery-slide-inner:hover img { transform: scale(1.06); }
  .gallery-slide-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(8,8,16,0.75) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex; flex-direction: column; align-items: center; justify-content: flex-end;
    padding: 24px 18px;
    gap: 8px;
  }
  .gallery-slide-inner:hover .gallery-slide-overlay,
  .gallery-slide-inner:focus-visible .gallery-slide-overlay { opacity: 1; }
  .gallery-slide-zoom {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(255,133,194,0.20);
    border: 1.5px solid rgba(255,133,194,0.50);
    display: flex; align-items: center; justify-content: center;
    color: var(--rose-bright);
    box-shadow: 0 0 20px rgba(255,133,194,0.40);
  }
  .gallery-slide-zoom svg { width: 18px; height: 18px; }
  .gallery-slide-label {
    color: var(--ink); font-size: 0.88rem; font-weight: 500;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  }

  /* Lightbox */
  .gallery-lightbox {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(5,5,12,0.95);
    backdrop-filter: blur(16px);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .gallery-lightbox.lb-open { opacity: 1; pointer-events: auto; }
  .gallery-lb-img-wrap {
    max-width: 90vw; max-height: 88vh;
    border-radius: var(--r-lg); overflow: hidden;
    box-shadow: 0 0 80px rgba(255,133,194,0.20), 0 32px 80px rgba(0,0,0,0.7);
    border: 1px solid rgba(255,133,194,0.20);
  }
  .gallery-lb-img-wrap img {
    max-width: 90vw; max-height: 88vh;
    object-fit: contain; display: block;
  }
  .gallery-lb-close,
  .gallery-lb-prev,
  .gallery-lb-next {
    position: absolute;
    background: rgba(255,133,194,0.10);
    border: 1px solid rgba(255,133,194,0.25);
    color: var(--ink);
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, transform 0.2s;
  }
  .gallery-lb-close { top: 20px; right: 20px; width: 44px; height: 44px; }
  .gallery-lb-close svg { width: 18px; height: 18px; }
  .gallery-lb-prev { left: 16px; width: 52px; height: 52px; }
  .gallery-lb-next { right: 16px; width: 52px; height: 52px; }
  .gallery-lb-prev svg, .gallery-lb-next svg { width: 22px; height: 22px; }
  .gallery-lb-close:hover,
  .gallery-lb-prev:hover,
  .gallery-lb-next:hover {
    background: rgba(255,133,194,0.22);
    transform: scale(1.1);
  }
  .gallery-lb-counter {
    position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
    color: var(--ink-soft); font-size: 0.82rem; letter-spacing: 0.1em;
    background: rgba(8,8,16,0.6); padding: 4px 14px; border-radius: 999px;
  }

  @media (max-width: 580px) {
    .gallery-lb-prev { left: 6px; width: 40px; height: 40px; }
    .gallery-lb-next { right: 6px; width: 40px; height: 40px; }
  }
</style>
