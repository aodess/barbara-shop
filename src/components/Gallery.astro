---
import content from '../data/content.json';
import { t } from '../lib/i18n.js';
const { lang } = Astro.props;
const tr = t(lang);
const photos = content.gallery.photos;
---
<section class="gallery" id="gallery">
  <div class="container">
    <div class="section-head gallery-head">
      <span class="eyebrow">{tr.gallery.eyebrow}</span>
      <h2>{tr.gallery.title}</h2>
      <p class="section-intro">{lang === 'ru' ? 'Живые результаты наших мастеров — натуральные, стойкие, безупречные.' : lang === 'he' ? 'תוצאות אמיתיות של המעצבות שלנו — טבעיות, עמידות, מושלמות.' : 'Real results from our artists — natural, lasting, flawless.'}</p>
    </div>

    <div class="splide gallery-splide" id="gallery-splide" aria-label={tr.gallery.title}>
      <div class="splide__track gallery-track">
        <ul class="splide__list">
          {photos.map(photo => (
            <li class="splide__slide gallery-slide">
              <div class="gallery-slide-inner">
                <img src={photo.src} alt={photo.alt?.[lang] || ''} loading="lazy" />
                <div class="gallery-slide-overlay">
                  <span class="gallery-slide-label">{photo.alt?.[lang] || ''}</span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Splide !== 'undefined' && document.getElementById('gallery-splide')) {
      new Splide('#gallery-splide', {
        type:         'loop',
        perPage:      3,
        perMove:      1,
        gap:          '1.5rem',
        autoplay:     true,
        interval:     4500,
        pauseOnHover: true,
        breakpoints: {
          900: { perPage: 2 },
          580: { perPage: 1 },
        },
      }).mount();
    }
  });
</script>

<style>
  .gallery-head { margin-bottom: 40px; }
  .gallery-head h2 { margin: 12px 0 16px; }
  .gallery-track { border-radius: 24px; overflow: visible; }
  .gallery-slide-inner {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: var(--surface-raised);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .gallery-slide-inner img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .gallery-slide:hover .gallery-slide-inner img { transform: scale(1.04); }
  .gallery-slide-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(12,12,16,0.7) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex; align-items: flex-end;
    padding: 20px 18px;
  }
  .gallery-slide:hover .gallery-slide-overlay { opacity: 1; }
  .gallery-slide-label {
    color: var(--ink); font-size: 0.92rem; font-weight: 500;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  }
  .splide__arrow {
    background: rgba(221,184,122,0.15);
    border: 1px solid rgba(221,184,122,0.30);
    backdrop-filter: blur(10px);
    width: 44px; height: 44px; border-radius: 50%;
  }
  .splide__arrow svg { fill: var(--gold); }
  .splide__arrow:hover { background: rgba(221,184,122,0.28); }
  .splide__pagination__page {
    background: rgba(221,184,122,0.30); border-radius: 3px; width: 18px; height: 3px;
    transition: background 0.25s, width 0.25s;
  }
  .splide__pagination__page.is-active { background: var(--gold); width: 28px; }
</style>
