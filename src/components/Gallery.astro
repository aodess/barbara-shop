---
import content from '../data/content.json';
import { t } from '../lib/i18n.js';
const { lang } = Astro.props;
const tr = t(lang);
const photos = content.gallery.photos;
---
<section class="gallery" id="gallery">
  <div class="container">
    <div class="section-head gallery-head">
      <span class="eyebrow">{tr.gallery.eyebrow}</span>
      <h2>{tr.gallery.title}</h2>
      <p class="section-intro">{lang === 'ru' ? 'Живые результаты наших мастеров — натуральные, стойкие, безупречные.' : lang === 'he' ? 'תוצאות אמיתיות של המעצבות שלנו — טבעיות, עמידות, מושלמות.' : 'Real results from our artists — natural, lasting, flawless.'}</p>
    </div>

    <!-- Слайд-шоу с плавным переходом (некликабельное) -->
    <div class="gallery-fader" id="gallery-fader" aria-label={tr.gallery.title}>
      {photos.map((photo, idx) => (
        <div class={`gallery-slide-inner${idx === 0 ? ' is-active' : ''}`}>
          <img src={photo.src} alt={photo.alt?.[lang] || ''} loading={idx === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>

    <div class="gallery-dots" aria-hidden="true">
      {photos.map((_, idx) => (
        <span class={`gallery-dot${idx === 0 ? ' is-active' : ''}`}></span>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var fader = document.getElementById('gallery-fader');
    if (!fader) return;
    var slides = Array.prototype.slice.call(fader.querySelectorAll('.gallery-slide-inner'));
    var dots = Array.prototype.slice.call(document.querySelectorAll('.gallery-dot'));
    var idx = 0;
    if (slides.length > 1) {
      setInterval(function() {
        idx = (idx + 1) % slides.length;
        slides.forEach(function(s, n) { s.classList.toggle('is-active', n === idx); });
        dots.forEach(function(d, n) { d.classList.toggle('is-active', n === idx); });
      }, 2000);
    }
  });
</script>

<style>
  .gallery-head { margin-bottom: 40px; }
  .gallery-head h2 { margin: 12px 0 16px; }

  /* Слайд-шоу — короче чем 3/4, фото обрезается снизу через object-position */
  .gallery-fader {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 4/5;
    max-width: 420px;
    margin: 0 auto;
    background: var(--surface-raised);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    border: 1px solid rgba(255,133,194,0.18);
  }

  .gallery-slide-inner {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity 1s ease;
    /* Лёгкий зум — клиппит светлые рамки, которые есть в исходниках фото */
    transform: scale(1.05);
    transform-origin: center center;
  }
  .gallery-slide-inner.is-active { opacity: 1; }
  .gallery-slide-inner img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  /* Точки-индикаторы (декор, не кликаются) */
  .gallery-dots {
    display: flex; justify-content: center; gap: 8px;
    margin-top: 18px;
    pointer-events: none;
  }
  .gallery-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,133,194,0.25);
    transition: background 0.3s ease, transform 0.3s ease;
  }
  .gallery-dot.is-active {
    background: var(--rose-bright);
    transform: scale(1.35);
    box-shadow: 0 0 10px rgba(255,133,194,0.7);
  }
</style>
