---
import content from '../data/content.json';
import { pick } from '../lib/i18n.js';
const { lang } = Astro.props;
---

<section class="menu-section" id="menu">
  <div class="menu-bg-glow-left"></div>
  <div class="menu-bg-glow-right"></div>
  <div class="container">

    <div class="menu-head">
      <span class="eyebrow">{pick({ ru: 'Прайс-лист', he: 'מחירון', en: 'Price List' }, lang)}</span>
      <h2>{pick({ ru: 'Полное меню услуг', he: 'תפריט שירותים מלא', en: 'Full Service Menu' }, lang)}</h2>
      <p class="section-intro">{pick({ ru: 'Прозрачные цены без скрытых доплат. Запись — через WhatsApp.', he: 'מחירים שקופים ללא תוספות נסתרות. קביעת תור דרך וואטסאפ.', en: 'Transparent pricing, no hidden fees. Book via WhatsApp.' }, lang)}</p>
    </div>

    <div class="menu-layout">
      <!-- left: photo of the salon's menu/ambience -->
      <div class="menu-photo-col">
        <div class="menu-photo-frame">
          <img src="/images/skin-menu.jpg" alt="Barbara Shop menu" class="menu-photo" />
          <div class="menu-photo-badge">
            <svg viewBox="0 0 60 60" fill="none" width="24" height="24">
              <path d="M30 5 L33 22 L50 22 L37 32 L42 50 L30 40 L18 50 L23 32 L10 22 L27 22Z" fill="currentColor"/>
            </svg>
            <span>{pick({ ru: 'Премиум качество', he: 'איכות פרימיום', en: 'Premium Quality' }, lang)}</span>
          </div>
        </div>

        <!-- quick stats below photo -->
        <div class="menu-stats">
          <div class="mstat">
            <span class="mstat-num text-gradient-gold">{content.services.length}</span>
            <span class="mstat-label">{pick({ ru: 'Услуг', he: 'שירותים', en: 'Services' }, lang)}</span>
          </div>
          <div class="mstat-div"></div>
          <div class="mstat">
            <span class="mstat-num text-gradient-rose">{content.googleReviews.rating}</span>
            <span class="mstat-label">Google</span>
          </div>
          <div class="mstat-div"></div>
          <div class="mstat">
            <span class="mstat-num text-gradient-gold">3</span>
            <span class="mstat-label">{pick({ ru: 'Мастера', he: 'מעצבות', en: 'Artists' }, lang)}</span>
          </div>
        </div>
      </div>

      <!-- right: price list -->
      <div class="menu-price-list">
        {content.services.map((service, idx) => (
          <div class="menu-item">
            <div class="menu-item-num">
              <span>{String(idx + 1).padStart(2, '0')}</span>
            </div>
            <div class="menu-item-body">
              <div class="menu-item-row">
                <p class="menu-item-name">{service.name[lang] || service.name.ru}</p>
                <div class="menu-item-dots"></div>
                <span class="menu-item-price">{service.price} {content.pricing.currencySymbol}</span>
              </div>
              <p class="menu-item-desc">{service.description[lang] || service.description.ru}</p>
              <span class="menu-item-dur">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {service.duration} {pick({ ru: 'мин', he: 'דקות', en: 'min' }, lang)}
              </span>
            </div>
          </div>
        ))}

        <div class="menu-cta-row">
          <button class="btn btn-primary" type="button" data-booking-open>
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {pick({ ru: 'Записаться сейчас', he: 'קביעת תור עכשיו', en: 'Book Now' }, lang)}
          </button>
          <p class="menu-cta-note">{pick({ ru: 'Ответим в WhatsApp в течение часа', he: 'נגיב בוואטסאפ תוך שעה', en: 'We reply on WhatsApp within an hour' }, lang)}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .menu-section {
    background: var(--surface);
    position: relative; overflow: hidden;
  }
  .menu-bg-glow-left {
    position: absolute; top: 50%; left: -200px; transform: translateY(-50%);
    width: 500px; height: 500px; border-radius: 50%;
    background: radial-gradient(circle, rgba(224,144,180,0.10), transparent 70%);
    pointer-events: none;
  }
  .menu-bg-glow-right {
    position: absolute; top: 0; right: -150px;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, rgba(221,184,122,0.08), transparent 70%);
    pointer-events: none;
  }
  .menu-head { max-width: 640px; margin-bottom: 52px; }
  .menu-head h2 { margin: 16px 0 16px; }

  .menu-layout {
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.1fr);
    gap: 56px;
    align-items: start;
  }

  /* Photo column */
  .menu-photo-col { display: grid; gap: 28px; }
  .menu-photo-frame {
    position: relative;
    border-radius: 32px; overflow: hidden;
    border: 1px solid rgba(221,184,122,0.22);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 80px rgba(221,184,122,0.12);
    aspect-ratio: 3/4;
  }
  .menu-photo {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .menu-photo-frame:hover .menu-photo { transform: scale(1.03); }
  .menu-photo-badge {
    position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
    display: inline-flex; align-items: center; gap: 10px;
    background: linear-gradient(135deg, rgba(221,184,122,0.90), rgba(184,146,42,0.85));
    color: #fff; padding: 12px 22px; border-radius: 999px;
    font-size: 0.84rem; font-weight: 700; letter-spacing: 0.06em;
    box-shadow: 0 8px 28px rgba(0,0,0,0.4), 0 0 30px rgba(221,184,122,0.30);
    white-space: nowrap;
  }
  .menu-stats {
    display: flex; align-items: center;
    background: linear-gradient(135deg, var(--surface-raised), var(--surface-high));
    border: 1px solid var(--line); border-radius: 20px;
    padding: 22px 24px;
  }
  .mstat { flex: 1; text-align: center; }
  .mstat-num { display: block; font-family: var(--font-display); font-size: 1.9rem; font-weight: 500; line-height: 1; }
  .mstat-label { display: block; font-size: 0.75rem; color: var(--ink-mute); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 5px; }
  .mstat-div { width: 1px; height: 42px; background: var(--line-strong); flex-shrink: 0; margin: 0 4px; }

  /* Price list */
  .menu-price-list { display: grid; gap: 0; }
  .menu-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px;
    padding: 22px 0;
    border-bottom: 1px solid var(--line);
    position: relative;
    transition: background 0.2s;
  }
  .menu-item:first-child { border-top: 1px solid var(--line); }
  .menu-item:hover { background: rgba(221,184,122,0.03); }
  .menu-item-num {
    display: flex; align-items: flex-start; justify-content: center;
    padding-top: 2px;
    font-family: var(--font-display); font-size: 1.1rem;
    background: linear-gradient(135deg, var(--gold), var(--rose));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 500; letter-spacing: -0.02em;
  }
  .menu-item-body { min-width: 0; }
  .menu-item-row {
    display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px;
  }
  .menu-item-name { font-size: 1.05rem; font-weight: 600; margin: 0; color: var(--ink); white-space: nowrap; }
  .menu-item-dots {
    flex: 1;
    border-bottom: 1px dashed rgba(221,184,122,0.18);
    margin-bottom: 4px; min-width: 20px;
  }
  .menu-item-price {
    font-family: var(--font-display); font-size: 1.25rem; font-weight: 500;
    color: var(--gold); text-shadow: 0 0 20px rgba(221,184,122,0.30);
    white-space: nowrap; flex-shrink: 0;
  }
  .menu-item-desc { font-size: 0.88rem; color: var(--ink-soft); margin: 0 0 8px; line-height: 1.5; }
  .menu-item-dur {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.78rem; color: var(--ink-mute);
  }

  .menu-cta-row { padding-top: 32px; display: grid; gap: 12px; }
  .menu-cta-note { margin: 0; color: var(--ink-mute); font-size: 0.88rem; text-align: center; }

  @media (max-width: 900px) {
    .menu-layout { grid-template-columns: 1fr; }
    .menu-photo-frame { aspect-ratio: 16/9; }
  }
</style>
