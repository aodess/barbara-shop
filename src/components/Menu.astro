---
import content from '../data/content.json';
import { t, pick } from '../lib/i18n.js';
const { lang } = Astro.props;
const tr = t(lang);
---
<section class="menu-section" id="menu">
  <div class="container menu-inner">
    <div class="menu-header">
      <span class="eyebrow">The Menu</span>
      <h2>{pick({ ru: 'Стильный прайс на уход', he: 'תפריט טיפוח מעודן', en: 'Signature Beauty Menu' }, lang)}</h2>
      <p>{pick({ ru: 'Здесь собраны самые популярные процедуры, оформленные как роскошное меню.', he: 'כאן אספנו את הטיפולים הנפוצים ביותר בעיצוב תפריט יוקרתי.', en: 'Our most sought-after treatments styled as a premium menu.' }, lang)}</p>
    </div>

    <div class="menu-grid">
      <div class="menu-preview">
        <img src="/images/skin-menu.jpg" alt="Barbara Shop menu" />
      </div>
      <div class="menu-content">
        {content.services.map(service => (
          <div class="menu-item">
            <div>
              <p class="menu-item-name">{service.name[lang] || service.name.ru}</p>
              <p class="menu-item-note">{service.description[lang] || service.description.ru}</p>
            </div>
            <div class="menu-item-price">{service.price} {content.pricing.currencySymbol}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
