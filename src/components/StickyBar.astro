---
import content from '../data/content.json';
import { pick } from '../lib/i18n.js';
const { lang } = Astro.props;
const whatsapp = content.contacts.whatsapp || '';
const waNum = whatsapp.replace(/\D/g, '');
const waMsg = encodeURIComponent(pick({
  ru: 'Здравствуйте! Хочу записаться.',
  he: 'שלום! אני רוצה לקבוע תור.',
  en: 'Hello! I would like to book a visit.'
}, lang));
---

<div class="sticky-bar" id="sticky-bar">
  <button class="sticky-btn sticky-btn--book" type="button" id="sticky-book-btn">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
    {pick({ ru: 'Записаться', he: 'קביעת תור', en: 'Book' }, lang)}
  </button>

  <a class="sticky-btn sticky-btn--wa" href={`https://wa.me/${waNum}?text=${waMsg}`} target="_blank" rel="noreferrer">
    <svg viewBox="0 0 24 24" fill="currentColor" style="width:15px;height:15px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    WhatsApp
  </a>
</div>

<style>
  .sticky-bar {
    position: fixed; z-index: 80;
    display: flex; pointer-events: none;
  }
  .sticky-bar > * { pointer-events: auto; }

  /* Общие стили кнопок */
  .sticky-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 8px;
    font-family: var(--font-body); font-size: 0.88rem; font-weight: 700;
    letter-spacing: 0.06em; border: none; cursor: pointer;
    transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s;
    white-space: nowrap; text-decoration: none;
    position: relative; overflow: hidden;
  }

  /* Записаться — розовая с формой лепестка */
  .sticky-btn--book {
    background: linear-gradient(135deg, var(--rose-bright) 0%, var(--rose) 50%, var(--rose-deep) 100%);
    color: #fff;
    padding: 14px 26px;
    border-radius: 28px 8px 28px 8px;
    box-shadow: 0 6px 28px rgba(255,133,194,0.45), 0 0 50px rgba(255,133,194,0.20);
  }
  .sticky-btn--book::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
    transform: translateX(-100%);
    animation: shimmer 3.5s ease-in-out infinite;
  }
  .sticky-btn--book:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 44px rgba(255,133,194,0.55), 0 0 70px rgba(255,133,194,0.30);
  }

  /* WhatsApp — зелёная с инвертированной формой */
  .sticky-btn--wa {
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    color: #fff;
    padding: 14px 26px;
    border-radius: 8px 28px 8px 28px;
    box-shadow: 0 6px 24px rgba(37,211,102,0.35), 0 0 40px rgba(37,211,102,0.15);
  }
  .sticky-btn--wa:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(37,211,102,0.50);
  }

  /* Мобильная версия — полный экран снизу */
  @media (max-width: 640px) {
    .sticky-bar {
      inset-inline: 0; bottom: 0;
      padding: 10px 12px calc(10px + env(safe-area-inset-bottom, 0px));
      background: rgba(8,8,16,0.94);
      border-top: 1px solid rgba(255,133,194,0.15);
      backdrop-filter: saturate(140%) blur(16px);
      box-shadow: 0 -8px 28px rgba(0,0,0,0.5), 0 -1px 0 rgba(255,133,194,0.08);
      pointer-events: auto; gap: 10px;
    }
    .sticky-btn { flex: 1; padding: 13px 10px; }
    /* На мобильном — скруглённые, не лепесток */
    .sticky-btn--book { border-radius: 14px 6px 14px 6px; }
    .sticky-btn--wa   { border-radius: 6px 14px 6px 14px; }
    body { padding-bottom: 78px; }
  }

  /* Десктоп — плавающие справа снизу */
  @media (min-width: 641px) {
    .sticky-bar { bottom: 28px; inset-inline-end: 28px; gap: 10px; flex-direction: column; }
  }

  @keyframes shimmer {
    0%   { transform: translateX(-100%); }
    60%  { transform: translateX(100%); }
    100% { transform: translateX(100%); }
  }
</style>

<script is:inline>
  var stickyBook = document.getElementById('sticky-book-btn');
  var bookingSoon = document.getElementById('booking-soon');
  if (stickyBook && bookingSoon) {
    stickyBook.addEventListener('click', function() {
      bookingSoon.classList.add('is-open');
    });
  }
</script>
