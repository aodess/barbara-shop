---
import content from '../data/content.json';
import { pick } from '../lib/i18n.js';
const { lang } = Astro.props;

// Разбиваем все услуги на страницы по 4 (категория сохраняется в каждом item)
const allItems = content.hairServices.flatMap(cat =>
  cat.items.map(item => ({ ...item, catName: cat.name }))
);
const PER_PAGE = 4;
const pages: typeof allItems[] = [];
for (let i = 0; i < allItems.length; i += PER_PAGE) {
  pages.push(allItems.slice(i, i + PER_PAGE));
}
---

<section class="hair-section" id="hair">
  <div class="container">

    <div class="section-head">
      <span class="eyebrow">
        {pick({ ru: 'Прайс-лист', he: 'תפריט', en: 'Price Menu' }, lang)}
      </span>
      <h2>
        {pick({ ru: 'Причёски', he: 'תספורות וטיפולים', en: 'Hair Services' }, lang)}
      </h2>
      <p class="section-intro">
        {pick({
          ru: 'Листай карточки, чтобы увидеть все услуги и цены',
          he: 'החלקי את הכרטיסיות לראות את כל השירותים והמחירים',
          en: 'Swipe the cards to see all services and prices'
        }, lang)}
      </p>
    </div>

    <!-- Карусель -->
    <div class="hair-carousel-outer">
      <!-- Счётчик слайдов -->
      <div class="hair-counter" aria-live="polite">
        <span class="hair-counter-cur" id="hair-cur">01</span>
        <span class="hair-counter-sep">✦</span>
        <span class="hair-counter-tot" id="hair-tot">01</span>
      </div>

      <div class="hair-carousel-wrap">
        <button class="hair-arrow hair-arrow--prev" id="hair-prev" aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="splide hair-splide" id="hair-splide" data-count={pages.length.toString()} aria-label="Hair Services">
          <div class="splide__track">
            <ul class="splide__list">
              {pages.map((items, idx) => (
                <li class="splide__slide">
                  <div class="price-card card-ornament">
                  <div class="price-card-header">

                    <div class="price-card-icon">
                      <!-- Ножницы -->
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="cat-svg">
                        <circle cx="6" cy="6" r="3"/>
                        <circle cx="6" cy="18" r="3"/>
                        <line x1="20" y1="4" x2="8.12" y2="15.88"/>
                        <line x1="14.47" y1="14.48" x2="20" y2="20"/>
                        <line x1="8.12" y1="8.12" x2="12" y2="12"/>
                      </svg>
                    </div>

                    <div class="price-card-title">
                      <span class="price-cat-label">
                        {pick({ ru: 'Прайс-лист', he: 'מחירון', en: 'Price List' }, lang)}
                      </span>
                      <h3 class="price-cat-name">
                        {pick({ ru: 'Услуги', he: 'שירותים', en: 'Services' }, lang)} · {idx + 1}
                      </h3>
                    </div>
                  </div>

                  <div class="price-items">
                    {items.map((item, i) => (
                      <div class={`price-item${i < items.length - 1 ? ' price-item--border' : ''}`}>
                        <div class="price-item-top">
                          <span class="price-item-name">{pick(item.name, lang)}</span>
                          <span class="price-item-price">{item.price}</span>
                        </div>
                        <p class="price-item-note">"{pick(item.note, lang)}"</p>
                      </div>
                    ))}
                  </div>

                  <div class="price-card-footer">
                    <span class="price-card-heart">♥ ♥ ♥</span>
                  </div>
                </div>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <button class="hair-arrow hair-arrow--next" id="hair-next" aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var el  = document.getElementById('hair-splide');
    var cnt = el ? parseInt(el.dataset.count || '1') : 1;
    var cur = document.getElementById('hair-cur');
    var tot = document.getElementById('hair-tot');
    if (tot) tot.textContent = String(cnt).padStart(2, '0');

    var sp = new Splide('#hair-splide', {
      type:       'loop',
      perPage:    1,
      gap:        '1.5rem',
      autoplay:   false,
      pauseOnHover: true,
      pagination: true,
      arrows:     false,
      speed:      700,
    }).mount();

    sp.on('moved', function(newIdx) {
      if (cur) cur.textContent = String(newIdx + 1).padStart(2, '0');
    });

    var prev = document.getElementById('hair-prev');
    var next = document.getElementById('hair-next');
    prev && prev.addEventListener('click', function() { sp.go('<'); });
    next && next.addEventListener('click', function() { sp.go('>'); });
  });
</script>

<style>
  .hair-section { background: transparent; }

  /* Внешняя орнаментальная обёртка */
  .hair-carousel-outer {
    background: linear-gradient(145deg, rgba(255,20,147,0.04) 0%, rgba(240,216,152,0.02) 100%);
    border: 1px solid rgba(255,20,147,0.14);
    border-radius: var(--r-lg);
    padding: clamp(20px, 4vw, 36px);
    margin-bottom: 12px;
  }

  /* Счётчик слайдов */
  .hair-counter {
    display: flex; align-items: center; justify-content: flex-end;
    gap: 10px; margin-bottom: 16px;
  }
  .hair-counter-cur {
    font-family: var(--font-display); font-style: italic;
    font-size: 2.2rem; font-weight: 300;
    color: #FF1493;
    text-shadow: 0 0 20px rgba(255,20,147,0.70);
    line-height: 1;
  }
  .hair-counter-sep {
    color: rgba(255,20,147,0.40); font-size: 0.8rem;
    text-shadow: 0 0 10px rgba(255,20,147,0.50);
  }
  .hair-counter-tot {
    font-family: var(--font-display); font-style: italic;
    font-size: 1.1rem; font-weight: 300;
    color: rgba(255,20,147,0.40); line-height: 1;
  }

  /* Обёртка карусели с кнопками по бокам */
  .hair-carousel-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  /* Стрелки */
  .hair-arrow {
    flex-shrink: 0;
    width: 48px; height: 48px;
    border-radius: 50%;
    background: rgba(255,133,194,0.10);
    border: 1px solid rgba(255,133,194,0.30);
    color: var(--rose-bright);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    box-shadow: 0 0 20px rgba(255,133,194,0.15), inset 0 1px 0 rgba(255,255,255,0.06);
    transition: background 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .hair-arrow:hover {
    background: rgba(255,133,194,0.22);
    box-shadow: 0 0 36px rgba(255,133,194,0.35);
    transform: scale(1.08);
  }
  .hair-arrow svg { width: 20px; height: 20px; }
  .hair-splide { flex: 1; min-width: 0; }

  /* Карточка прайса */
  .price-card {
    background: linear-gradient(145deg, rgba(255,133,194,0.07) 0%, rgba(240,216,152,0.04) 100%);
    border: 1px solid rgba(255,133,194,0.18);
    border-radius: var(--r-lg);
    padding: clamp(24px, 5vw, 36px);
    min-height: 360px;
    display: flex; flex-direction: column;
    box-shadow: 0 8px 32px rgba(0,0,0,0.35), 0 0 60px rgba(255,133,194,0.06);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .price-card:hover {
    border-color: rgba(255,133,194,0.35);
    box-shadow: 0 12px 48px rgba(0,0,0,0.4), 0 0 80px rgba(255,133,194,0.14);
  }

  .price-card-header {
    display: flex; align-items: flex-start; gap: 16px;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255,133,194,0.12);
  }

  /* SVG иконка категории */
  .price-card-icon {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, rgba(255,20,147,0.28) 0%, rgba(255,133,194,0.10) 60%, transparent 100%);
    border: 1.5px solid rgba(255,20,147,0.45);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 24px rgba(255,20,147,0.22), inset 0 1px 0 rgba(255,255,255,0.10);
  }
  .cat-svg {
    width: 34px; height: 34px;
    color: #FF1493;
    filter:
      drop-shadow(0 0 6px rgba(255,20,147,1.0))
      drop-shadow(0 0 16px rgba(255,20,147,0.80))
      drop-shadow(0 0 32px rgba(255,20,147,0.45));
  }

  .price-cat-label {
    display: block; font-size: 0.64rem; font-weight: 600; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--rose-bright); margin-bottom: 4px;
    text-shadow: 0 0 12px rgba(255,133,194,0.50);
  }
  .price-cat-name {
    font-family: var(--font-script); font-size: 1.7rem; font-weight: 600;
    color: var(--ink); margin: 0; line-height: 1.1;
  }

  .price-items { display: flex; flex-direction: column; gap: 0; flex: 1; }
  .price-item { padding: 14px 0; }
  .price-item--border { border-bottom: 1px solid rgba(255,133,194,0.08); }

  .price-item-top {
    display: flex; align-items: baseline;
    justify-content: space-between; gap: 12px;
    margin-bottom: 5px;
  }
  .price-item-name {
    font-family: var(--font-display); font-weight: 500;
    font-size: 1rem; color: var(--ink);
  }
  .price-item-price {
    font-family: var(--font-display); font-weight: 600;
    font-size: 1rem; color: var(--gold); white-space: nowrap; flex-shrink: 0;
    text-shadow: 0 0 16px rgba(240,216,152,0.50);
  }
  .price-item-note {
    font-size: 0.82rem; color: var(--ink-mute); font-style: italic;
    margin: 0; line-height: 1.5;
  }

  .price-card-footer { margin-top: auto; padding-top: 16px; text-align: center; }
  .price-card-heart {
    color: var(--rose-bright); font-size: 0.85rem;
    opacity: 0.5; letter-spacing: 8px;
    text-shadow: 0 0 10px rgba(255,133,194,0.60);
  }

  /* RTL fix — зеркалим стрелки чтобы они смотрели наружу */
  [dir="rtl"] .hair-arrow svg { transform: scaleX(-1); }

  @keyframes iconPulse {
    0%, 100% { box-shadow: 0 0 24px rgba(255,133,194,0.22); }
    50%       { box-shadow: 0 0 56px rgba(255,133,194,0.55), 0 0 100px rgba(255,133,194,0.25); }
  }
  .price-card-icon { animation: iconPulse 3.2s ease-in-out infinite; }

  @media (max-width: 600px) {
    .hair-carousel-wrap { gap: 6px; }
    .hair-arrow { width: 36px; height: 36px; }
    .hair-arrow svg { width: 16px; height: 16px; }
  }
</style>
