---
import content from '../data/content.json';
import { t, pick } from '../lib/i18n.js';
import { whatsappLink } from '../lib/seo.js';
const { lang } = Astro.props;
const tr = t(lang);
const hours = content.hours;
const whatsapp = content.contacts.whatsapp || '+972501234567';
const mapUrl = content.salon.googleMapsUrl || `https://www.google.com/maps/search/${encodeURIComponent(pick(content.salon.city, lang) || 'Bat Yam')}`;

const dayOrder = ['sun','mon','tue','wed','thu','fri','sat'];
---

<section class="contacts" id="contacts">
  <div class="contacts-glow"></div>
  <div class="container">
    <div class="contacts-header">
      <span class="eyebrow">{tr.contacts.title}</span>
      <h2>{pick({ ru: 'Приходите к нам', he: 'בואו אלינו', en: 'Visit Us' }, lang)}</h2>
      <p class="section-intro">{pick({ ru: 'Запись только через WhatsApp. Ответим быстро и подберём удобное время.', he: 'קביעת תורים דרך וואטסאפ בלבד. נגיב מהר ונתאם זמן נוח.', en: 'Bookings via WhatsApp only. We respond fast and find a convenient time.' }, lang)}</p>
    </div>

    <div class="contacts-grid">
      <!-- Info card -->
      <div class="contacts-info">
        <div class="cinfo-block">
          <div class="cinfo-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <p class="cinfo-label">{tr.contacts.address}</p>
            <p class="cinfo-value">{pick(content.salon.address, lang)}</p>
          </div>
        </div>

        <div class="cinfo-block">
          <div class="cinfo-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <p class="cinfo-label">{pick({ ru: 'Запись', he: 'קביעת תור', en: 'Booking' }, lang)}</p>
            <p class="cinfo-value">{tr.contacts.writePrefer}</p>
          </div>
        </div>

        <div class="contacts-actions">
          <a class="btn btn-whatsapp" href={whatsappLink(whatsapp)} target="_blank" rel="noreferrer">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a class="btn btn-map" href={mapUrl} target="_blank" rel="noreferrer">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
            {tr.cta.viewMap}
          </a>
        </div>
      </div>

      <!-- Hours card -->
      <div class="contacts-hours">
        <div class="hours-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>{tr.contacts.schedule}</span>
        </div>
        <div class="hours-list">
          {dayOrder.map(key => {
            const day = hours[key];
            if (!day) return null;
            return (
              <div class="hours-row" key={key}>
                <span class="hours-day">{tr.hours[key]}</span>
                <div class="hours-dots"></div>
                <span class="hours-time">
                  {day.closed
                    ? <span class="hours-closed">{pick({ ru: 'Выходной', he: 'סגור', en: 'Closed' }, lang)}</span>
                    : <span class="hours-range">{day.open} — {day.close}</span>
                  }
                </span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Map placeholder -->
      <div class="contacts-map-col">
        <div class="contacts-map-card">
          {content.salon.googleMapsEmbedUrl && content.salon.googleMapsEmbedUrl.includes('embed') ? (
            <iframe
              src={content.salon.googleMapsEmbedUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Barbara Shop on Google Maps"
            ></iframe>
          ) : (
            <div class="map-placeholder">
              <svg viewBox="0 0 80 80" fill="none" width="64" height="64" style="opacity:0.3">
                <path d="M40 8C26.745 8 16 18.745 16 32c0 20 24 40 24 40s24-20 24-40C64 18.745 53.255 8 40 8zm0 32a8 8 0 110-16 8 8 0 010 16z" fill="var(--gold)"/>
              </svg>
              <p>{pick({ ru: 'Карта появится здесь после добавления ссылки Google Maps.', he: 'המפה תופיע כאן לאחר הוספת קישור Google Maps.', en: 'Map will appear here after adding a Google Maps link.' }, lang)}</p>
              <a class="btn btn-ghost" href={mapUrl} target="_blank" rel="noreferrer">
                {tr.cta.viewMap}
              </a>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contacts { position: relative; background: var(--surface); overflow: hidden; }
  .contacts-glow {
    position: absolute; bottom: -120px; left: 50%; transform: translateX(-50%);
    width: 700px; height: 350px;
    background: radial-gradient(ellipse, rgba(224,144,180,0.07), transparent 70%);
    pointer-events: none;
  }
  .contacts-header { max-width: 620px; margin-bottom: 52px; }
  .contacts-header h2 { margin: 16px 0 16px; }

  .contacts-grid {
    display: grid;
    grid-template-columns: minmax(280px,1fr) minmax(220px,0.7fr) minmax(280px,1fr);
    gap: 28px;
    align-items: start;
  }

  /* Info */
  .contacts-info {
    background: linear-gradient(155deg, var(--surface-raised) 0%, var(--surface-high) 100%);
    border: 1px solid var(--line); border-radius: 28px;
    padding: 32px 28px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    display: grid; gap: 28px;
  }
  .cinfo-block { display: flex; gap: 18px; align-items: flex-start; }
  .cinfo-icon {
    width: 44px; height: 44px; border-radius: 14px; flex-shrink: 0;
    background: linear-gradient(135deg, rgba(221,184,122,0.15), rgba(224,144,180,0.10));
    border: 1px solid rgba(221,184,122,0.20);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold);
  }
  .cinfo-label { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.10em; text-transform: uppercase; color: var(--gold); margin: 0 0 6px; }
  .cinfo-value { color: var(--ink-soft); margin: 0; font-size: 0.95rem; line-height: 1.5; }
  .contacts-actions { display: flex; flex-direction: column; gap: 12px; }
  .contacts-actions .btn { width: 100%; justify-content: center; }

  /* Hours */
  .contacts-hours {
    background: linear-gradient(155deg, var(--surface-raised) 0%, var(--surface-high) 100%);
    border: 1px solid var(--line); border-radius: 28px;
    padding: 28px 24px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  }
  .hours-header {
    display: flex; align-items: center; gap: 10px;
    color: var(--gold); font-size: 0.80rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 20px;
    text-shadow: 0 0 16px rgba(221,184,122,0.40);
  }
  .hours-list { display: grid; gap: 12px; }
  .hours-row { display: flex; align-items: center; gap: 8px; }
  .hours-day { color: var(--ink-soft); font-size: 0.90rem; min-width: 28px; }
  .hours-dots { flex: 1; border-bottom: 1px dashed rgba(255,255,255,0.10); }
  .hours-time { font-size: 0.88rem; white-space: nowrap; }
  .hours-range { color: var(--ink); }
  .hours-closed { color: var(--ink-mute); font-style: italic; }

  /* Map */
  .contacts-map-col {}
  .contacts-map-card {
    border-radius: 28px; overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    background: var(--surface-raised);
    min-height: 320px;
  }
  .contacts-map-card iframe {
    width: 100%; min-height: 380px; border: 0; display: block;
  }
  .map-placeholder {
    min-height: 320px; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 20px; padding: 36px 28px; text-align: center;
  }
  .map-placeholder p { color: var(--ink-soft); font-size: 0.95rem; max-width: 280px; margin: 0; }

  @media (max-width: 1100px) {
    .contacts-grid { grid-template-columns: 1fr 1fr; }
    .contacts-map-col { grid-column: 1/-1; }
    .contacts-map-card { min-height: 260px; }
    .contacts-map-card iframe { min-height: 300px; }
  }
  @media (max-width: 640px) {
    .contacts-grid { grid-template-columns: 1fr; }
  }
</style>
