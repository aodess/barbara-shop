---
import content from '../data/content.json';
import { pick } from '../lib/i18n.js';
const { lang } = Astro.props;
const whatsapp = content.contacts.whatsapp || '';
const waNum = whatsapp.replace(/\D/g, '');
const instagram = content.contacts.instagram || '#';
const instagramHandle = content.contacts.instagramHandle || '@barbara.shop';
const mapUrl = content.salon.googleMapsUrl || '#';

const dayOrder = ['sun','mon','tue','wed','thu','fri','sat'];
const dayNames: Record<string, Record<string, string>> = {
  sun: { ru: 'Вс', he: 'א׳', en: 'Sun' },
  mon: { ru: 'Пн', he: 'ב׳', en: 'Mon' },
  tue: { ru: 'Вт', he: 'ג׳', en: 'Tue' },
  wed: { ru: 'Ср', he: 'ד׳', en: 'Wed' },
  thu: { ru: 'Чт', he: 'ה׳', en: 'Thu' },
  fri: { ru: 'Пт', he: 'ו׳', en: 'Fri' },
  sat: { ru: 'Сб', he: 'ש׳', en: 'Sat' },
};
const hours = content.hours as Record<string, {closed?: boolean; open?: string; close?: string}>;
---

<section class="contacts-section" id="contacts">
  <div class="container">

    <div class="section-head" style="text-align:center;align-items:center;">
      <span class="eyebrow">
        {pick({ ru: 'Связь', he: 'צור קשר', en: 'Contact' }, lang)}
      </span>
      <h2>
        {pick({ ru: 'Приходите к нам', he: 'בואי אלינו', en: 'Visit Us' }, lang)}
      </h2>
      <p class="section-intro" style="margin:0 auto;">
        {pick({
          ru: 'Запись через WhatsApp. Ответим быстро ♥',
          he: 'קביעת תורים דרך וואטסאפ. נגיב מהר ♥',
          en: 'Bookings via WhatsApp. We respond fast ♥'
        }, lang)}
      </p>
    </div>

    <div class="contacts-grid">

      <!-- Часы -->
      <div class="contacts-card">
        <div class="contacts-card-icon">
          <!-- Clock SVG -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="contacts-icon-svg">
            <circle cx="12" cy="12" r="9"/>
            <polyline points="12 7 12 12 15.5 14.5"/>
            <circle cx="12" cy="12" r="1" fill="currentColor"/>
          </svg>
        </div>
        <h3 class="contacts-card-title">
          {pick({ ru: 'Часы работы', he: 'שעות פתיחה', en: 'Opening Hours' }, lang)}
        </h3>
        <ul class="hours-list">
          {dayOrder.map(key => {
            const day = hours[key];
            if (!day) return null;
            return (
              <li class="hours-row">
                <span class="hours-day">{pick(dayNames[key], lang)}</span>
                <span class="hours-dots-line"></span>
                <span class="hours-time">
                  {day.closed
                    ? <span class="hours-closed">{pick({ ru: 'Выходной', he: 'סגור', en: 'Closed' }, lang)}</span>
                    : <>{day.open} — {day.close}</>
                  }
                </span>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Адрес + соцсети -->
      <div class="contacts-card">
        <div class="contacts-card-icon">
          <!-- Pin SVG -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="contacts-icon-svg">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
            <circle cx="12" cy="9" r="2.5" fill="currentColor" opacity="0.3"/>
          </svg>
        </div>
        <h3 class="contacts-card-title">
          {pick({ ru: 'Мы здесь', he: 'אנחנו כאן', en: 'Find Us' }, lang)}
        </h3>
        <p class="contacts-address">{pick(content.salon.city, lang)}</p>

        <div class="contacts-social">
          <a class="btn btn-whatsapp contacts-btn" href={`https://wa.me/${waNum}`} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" style="width:16px;height:16px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a class="btn btn-insta contacts-btn" href={instagram} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:16px;height:16px">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
            {instagramHandle}
          </a>
          <!-- Google Maps кнопка -->
          <a class="btn btn-maps contacts-btn" href={mapUrl} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="none" class="maps-icon" style="width:18px;height:18px">
              <!-- Google Maps styled pin -->
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="#EA4335"/>
              <path d="M12 2c3.87 0 7 3.13 7 7 0 5.25-7 13-7 13V2z" fill="#C5221F"/>
              <circle cx="12" cy="9" r="3" fill="white"/>
              <circle cx="12" cy="9" r="1.5" fill="#EA4335"/>
            </svg>
            {pick({ ru: 'Мы на Google Maps', he: 'אנחנו ב-Google Maps', en: 'Find on Google Maps' }, lang)}
          </a>
        </div>
      </div>

    </div>

    <!-- Декор снизу -->
    <div class="contacts-deco" aria-hidden="true">
      <svg viewBox="0 0 80 16" fill="none" class="contacts-deco-svg">
        <path d="M4 8 Q10 2 16 8 Q22 14 28 8 Q34 2 40 8 Q46 14 52 8 Q58 2 64 8 Q70 14 76 8" stroke="rgba(255,20,147,0.30)" stroke-width="1.5" fill="none"/>
      </svg>
      <span class="contacts-deco-hearts">♥ ♥ ♥</span>
      <svg viewBox="0 0 80 16" fill="none" class="contacts-deco-svg">
        <path d="M4 8 Q10 2 16 8 Q22 14 28 8 Q34 2 40 8 Q46 14 52 8 Q58 2 64 8 Q70 14 76 8" stroke="rgba(255,20,147,0.30)" stroke-width="1.5" fill="none"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .contacts-section { background: transparent; }

  .contacts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px; margin-top: 40px;
  }

  .contacts-card {
    background: linear-gradient(145deg, rgba(255,133,194,0.06), rgba(240,216,152,0.03));
    border: 1px solid rgba(255,133,194,0.16);
    border-radius: var(--r-lg);
    padding: clamp(20px, 4vw, 32px);
  }

  /* SVG иконка карточки */
  .contacts-card-icon {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, rgba(255,20,147,0.25) 0%, rgba(255,133,194,0.08) 60%, transparent 100%);
    border: 1.5px solid rgba(255,20,147,0.40);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px;
    box-shadow: 0 0 20px rgba(255,20,147,0.18), inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .contacts-icon-svg {
    width: 24px; height: 24px;
    color: #FF1493;
    filter:
      drop-shadow(0 0 4px rgba(255,20,147,0.9))
      drop-shadow(0 0 12px rgba(255,20,147,0.55));
  }

  .contacts-card-title {
    font-family: var(--font-script); font-size: 1.4rem; font-weight: 600;
    color: var(--rose-bright); margin: 0 0 16px;
  }

  /* Hours */
  .hours-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .hours-row { display: flex; align-items: center; gap: 8px; }
  .hours-day { font-size: 0.84rem; color: var(--ink-soft); min-width: 26px; }
  .hours-dots-line { flex: 1; height: 1px; border-bottom: 1px dashed rgba(255,133,194,0.15); }
  .hours-time { font-size: 0.84rem; color: var(--ink); white-space: nowrap; }
  .hours-closed { color: var(--ink-mute); font-style: italic; }

  /* Address */
  .contacts-address { font-family: var(--font-display); font-size: 1.1rem; color: var(--ink); margin: 0 0 4px; }
  .contacts-address-note { color: var(--ink-mute); font-size: 0.80rem; margin: 0 0 20px; font-style: italic; }

  /* Social buttons */
  .contacts-social { display: flex; flex-direction: column; gap: 10px; }
  .contacts-btn { width: 100%; justify-content: center; }
  .btn-insta {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: #fff; font-weight: 600;
    box-shadow: 0 6px 20px rgba(220, 39, 67, 0.25);
  }
  .btn-insta:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(220, 39, 67, 0.35); }

  /* Google Maps button */
  .btn-maps {
    background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    border: 1px solid rgba(234,67,53,0.35) !important;
    color: var(--ink);
    font-weight: 600;
    box-shadow: 0 4px 16px rgba(234,67,53,0.14);
  }
  .btn-maps:hover {
    transform: translateY(-2px);
    background: rgba(234,67,53,0.08);
    box-shadow: 0 8px 28px rgba(234,67,53,0.25);
    border-color: rgba(234,67,53,0.55) !important;
  }

  /* Deco */
  .contacts-deco {
    display: flex; align-items: center; justify-content: center;
    gap: 16px; margin-top: 48px;
  }
  .contacts-deco-svg { width: 100px; height: 16px; flex-shrink: 0; }
  .contacts-deco-hearts {
    color: var(--rose-bright); font-size: 0.9rem; opacity: 0.45;
    letter-spacing: 0.5em; white-space: nowrap;
    text-shadow: 0 0 10px rgba(255,133,194,0.60);
  }

</style>
