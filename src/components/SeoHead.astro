---
import content from '../data/content.json';
import { LOCALES, FALLBACK_LOCALE, pick } from '../lib/i18n.js';
import { buildJsonLd } from '../lib/seo.js';
const { lang } = Astro.props;
const siteUrl = (content.seo.siteUrl || '').replace(/\/$/, '');
const description = pick(content.salon.description, lang);
const title = content.brand.name;
const ogImage = content.seo.ogImage || '/images/logo.jpg';
const pageUrl = siteUrl ? `${siteUrl}/${lang}/` : `/${lang}/`;
---
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0C0C10" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {LOCALES.map((l) => (
    <link rel="alternate" hreflang={l} href={`${siteUrl}/${l}/`} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/${FALLBACK_LOCALE}/`} />
  <script type="application/ld+json" set:html={buildJsonLd(lang)}></script>
</head>
