---
import content from '../data/content.json';
import { pick } from '../lib/i18n.js';
const { lang } = Astro.props;
const masters = content.masters;
---

<section class="masters-section" id="masters">
  <div class="container">

    <div class="section-head">
      <span class="eyebrow">
        {pick({ ru: 'Наша команда', he: 'הצוות שלנו', en: 'Our Team' }, lang)}
      </span>
      <h2>
        {pick({ ru: 'Мастера', he: 'המאסטרות שלנו', en: 'Our Artists' }, lang)}
      </h2>
    </div>

    <div class="masters-box">
      <div class="masters-box-deco" aria-hidden="true">💋</div>

      <div class="splide masters-splide" id="masters-splide" aria-label="Our Masters">
        <div class="splide__track">
          <ul class="splide__list">
            {masters.map((master) => (
              <li class="splide__slide">
                <div class="master-card">
                  <div class="master-emoji">{master.emoji}</div>
                  <h3 class="master-name">{pick(master.name, lang)}</h3>
                  <p class="master-role">{pick(master.role, lang)}</p>
                  <div class="master-exp">
                    {master.experienceYears}+ {pick({ ru: 'лет', he: 'שנות', en: 'yrs' }, lang)}
                  </div>
                  <ul class="master-tags">
                    {(pick(master.specialties, lang) as string[]).map((s: string) => (
                      <li class="master-tag">{s}</li>
                    ))}
                  </ul>
                  <div class="photo-placeholder" style="aspect-ratio:1;border-radius:50%;max-width:100px;margin:12px auto 0;">
                    <span class="photo-placeholder-icon" style="font-size:1.4rem;">📸</span>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="masters-arrows">
        <button class="m-prev" aria-label="Previous">‹</button>
        <button class="m-next" aria-label="Next">›</button>
      </div>

      <p class="masters-hint">
        {pick({ ru: '← листай →', he: '← גלול →', en: '← swipe →' }, lang)}
      </p>
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
  var sp = new Splide('#masters-splide', {
    type:         'loop',
    perPage:      1,
    autoplay:     true,
    interval:     3500,
    pauseOnHover: true,
    pauseOnFocus: true,
    arrows:       false,
    pagination:   false,
  });
  sp.mount();

  var track = document.querySelector('#masters-splide .splide__track');
  if (track) {
    track.addEventListener('touchstart', function() { sp.Components.Autoplay.pause(); }, { passive: true });
    track.addEventListener('mousedown',  function() { sp.Components.Autoplay.pause(); });
  }

  var prev = document.querySelector('.m-prev');
  var next = document.querySelector('.m-next');
  prev && prev.addEventListener('click', function() { sp.go('<'); });
  next && next.addEventListener('click', function() { sp.go('>'); });
  });
</script>

<style>
  .masters-section { background: var(--paper); }

  .masters-box {
    position: relative;
    background: linear-gradient(145deg, rgba(255,133,194,0.06), rgba(240,216,152,0.03));
    border: 1px solid rgba(255,133,194,0.20);
    border-radius: var(--r-xl);
    padding: clamp(28px, 5vw, 48px) clamp(16px, 4vw, 40px) 20px;
    overflow: hidden;
    max-width: 460px; margin: 0 auto;
  }
  .masters-box-deco {
    position: absolute; top: 14px; right: 18px;
    font-size: 1.6rem; opacity: 0.12; pointer-events: none; line-height: 1;
  }

  .master-card {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; padding: 8px 16px 16px; gap: 8px;
  }
  .master-emoji { font-size: 2.8rem; line-height: 1; }
  .master-name {
    font-family: var(--font-script); font-size: 1.8rem; font-weight: 600;
    background: linear-gradient(135deg, var(--rose-bright), var(--gold));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0; line-height: 1.1;
  }
  .master-role { color: var(--ink-soft); font-size: 0.86rem; margin: 0; font-style: italic; }
  .master-exp {
    display: inline-block;
    padding: 4px 14px; border-radius: 999px;
    background: rgba(255,133,194,0.10); border: 1px solid rgba(255,133,194,0.20);
    color: var(--rose-bright); font-size: 0.74rem; font-weight: 600;
  }
  .master-tags {
    list-style: none; margin: 2px 0 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 5px; justify-content: center;
  }
  .master-tag {
    padding: 3px 11px; border-radius: 999px;
    background: rgba(240,216,152,0.08); border: 1px solid rgba(240,216,152,0.16);
    color: var(--gold); font-size: 0.73rem;
  }

  .masters-arrows {
    display: flex; justify-content: center; gap: 10px; margin: 14px 0 4px;
  }
  .masters-arrows button {
    width: 36px; height: 36px; border-radius: 50%; cursor: pointer;
    background: rgba(255,133,194,0.10); border: 1px solid rgba(255,133,194,0.25);
    color: var(--rose-bright); font-size: 1.2rem;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  .masters-arrows button:hover { background: rgba(255,133,194,0.20); }

  .masters-hint {
    text-align: center; color: var(--ink-mute); font-size: 0.74rem;
    letter-spacing: 0.16em; margin: 6px 0 0; padding-bottom: 4px;
  }
</style>
