---
import content from '../data/content.json';
import { pick } from '../lib/i18n.js';
import { computeStatus } from '../lib/businessHours.js';
const { lang } = Astro.props;
const status = computeStatus(content.hours);
---

<section class="hero" id="home">

  <!-- Граффити сердечки на Hero -->
  <div class="hero-graffiti" aria-hidden="true">
    <span class="hg hg-1">♥</span>
    <span class="hg hg-2">💋</span>
    <span class="hg hg-3">♥</span>
    <span class="hg hg-4">✦</span>
    <span class="hg hg-5">♥</span>
    <span class="hg hg-6">💋</span>
    <span class="hg hg-7">♥</span>
    <span class="hg hg-8">✦</span>
  </div>

  <div class="container">

    <!-- ТОП: лого + название -->
    <div class="hero-top fade-up">
      <div class="hero-logo-wrap">
        <div class="hero-logo-ring">
          <img class="hero-logo-img" src={content.brand.logo || '/images/logo.jpg'} alt={content.brand.name} />
        </div>
        <div class="hero-logo-glow" aria-hidden="true"></div>
        <div class="hero-logo-pulse" aria-hidden="true"></div>
      </div>
      <div class="hero-title-block">
        <p class="hero-city-label">
          ✦ {pick({ ru: 'Салон красоты · Петах-Тиква', he: 'סלון יופי · פתח תקווה', en: 'Beauty Salon · Petah Tikva' }, lang)} ✦
        </p>
        <h1 class="hero-title">{content.brand.name}</h1>
        <p class="hero-subtitle">{pick(content.salon.description, lang)}</p>
        <div class="hero-meta">
          <span class={`status-pill${status.open ? ' status-open' : ' status-closed'}`}>
            <span class="status-dot"></span>
            {status.open
              ? pick({ ru: 'Открыто', he: 'פתוח', en: 'Open' }, lang)
              : pick({ ru: 'Закрыто', he: 'סגור', en: 'Closed' }, lang)}
          </span>
          <a class="hero-rating" href={content.googleReviews.url} target="_blank" rel="noreferrer">
            <span class="hero-stars">★★★★★</span>
          </a>
        </div>
      </div>
    </div>

    <!-- ФОТО САЛОНА + описание -->
    <div class="hero-body fade-up" data-delay="2">
      <div class="hero-photo-slot">
        <div class="hero-photo-inner">
          <img class="hero-salon-img" src="/images/salon.webp" alt={pick({ ru: 'Салон Barbara Shop', he: 'סלון ברברה שופ', en: 'Barbara Shop Salon' }, lang)} loading="eager" />
          <div class="hero-photo-badge">
            <span class="badge-heart">♥</span>
            <span class="badge-text">
              {pick({ ru: 'Barbara Shop', he: 'ברברה שופ', en: 'Barbara Shop' }, lang)}
            </span>
          </div>
        </div>
        <div class="hero-photo-dot hero-photo-dot-1" aria-hidden="true"></div>
        <div class="hero-photo-dot hero-photo-dot-2" aria-hidden="true"></div>
      </div>

      <div class="hero-desc">
        <div class="hero-desc-deco" aria-hidden="true">♥</div>
        <h2 class="hero-desc-title">
          {pick({ ru: 'Место где ты\n— королева', he: 'המקום שבו את\n— מלכה', en: 'The place where\nyou reign' }, lang)}
        </h2>
        <p class="hero-desc-text">
          {pick({
            ru: 'Приходи за прической — уходи с улыбкой. Мы не просто делаем волосы, мы делаем настроение.',
            he: 'בואי לתספורת — לכי עם חיוך. אנחנו לא רק עושים שיער, אנחנו עושים את האווירה.',
            en: 'Come for hair — leave with a smile. We don\'t just style hair, we create moods.'
          }, lang)}
        </p>
        <div class="hero-desc-stats">
          <div class="hero-stat-item">
            <span class="hero-stat-num" data-count="20" data-suffix="+">0</span>
            <span class="hero-stat-label">{pick({ ru: 'лет опыта', he: 'שנות ניסיון', en: 'years exp' }, lang)}</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat-item">
            <span class="hero-stat-num" data-count="4.9" data-suffix="">0</span>
            <span class="hero-stat-label">Google</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat-item">
            <span class="hero-stat-num" data-count={content.googleReviews.count} data-suffix="+">0</span>
            <span class="hero-stat-label">{pick({ ru: 'отзывов', he: 'ביקורות', en: 'reviews' }, lang)}</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex; align-items: center;
    overflow: hidden;
    padding-block: clamp(100px, 14vw, 140px) clamp(60px, 8vw, 100px);
  }

  /* === ГРАФФИТИ === */
  .hero-graffiti { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .hg {
    position: absolute; line-height: 1; user-select: none;
    animation: hgFloat 7s ease-in-out infinite;
  }
  /* Текстовые сердечки — яркий неон */
  .hg-1  { top:6%;   left:2%;   font-size:5rem;  color:var(--rose-bright); opacity:0.18; transform:rotate(-20deg); animation-delay:0s; text-shadow:0 0 30px rgba(255,133,194,0.7); }
  .hg-2  { top:10%;  right:5%;  font-size:3rem;  opacity:0.22; animation-delay:1s; transform:rotate(15deg); filter:drop-shadow(0 0 16px rgba(255,133,194,0.8)); }
  .hg-3  { top:55%;  left:3%;   font-size:3.5rem;color:var(--rose-bright); opacity:0.14; transform:rotate(-10deg); animation-delay:2.5s; text-shadow:0 0 24px rgba(255,133,194,0.6); }
  .hg-4  { top:30%;  right:2%;  font-size:2.5rem;color:var(--gold); opacity:0.20; transform:rotate(5deg); animation-delay:1.5s; text-shadow:0 0 20px rgba(240,216,152,0.7); }
  .hg-5  { bottom:25%;left:7%;  font-size:4rem;  color:var(--rose-bright); opacity:0.12; transform:rotate(25deg); animation-delay:3s; text-shadow:0 0 28px rgba(255,133,194,0.5); }
  .hg-6  { bottom:15%;right:4%; font-size:2.8rem;opacity:0.18; animation-delay:0.5s; filter:drop-shadow(0 0 14px rgba(255,133,194,0.7)); }
  .hg-7  { top:75%;  left:50%;  font-size:2rem;  color:var(--rose); opacity:0.15; transform:rotate(-8deg); animation-delay:4s; }
  .hg-8  { top:20%;  left:45%;  font-size:1.5rem;color:var(--gold); opacity:0.12; animation-delay:2s; }

  @keyframes hgFloat {
    0%,100% { transform: translateY(0) rotate(var(--r,0deg)) scale(1); }
    50%      { transform: translateY(-14px) rotate(calc(var(--r,0deg) + 5deg)) scale(1.05); }
  }

  /* === ВЕРХНИЙ БЛОК === */
  .hero-top {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(20px, 4vw, 48px);
    align-items: center;
    margin-bottom: clamp(40px, 6vw, 72px);
    position: relative; z-index: 2;
  }

  /* Лого */
  .hero-logo-wrap { position: relative; flex-shrink: 0; }
  .hero-logo-ring {
    width: clamp(100px,16vw,140px); height: clamp(100px,16vw,140px);
    border-radius: 50%; overflow: hidden;
    border: 2px solid rgba(255,133,194,0.50);
    position: relative; z-index: 3;
  }
  .hero-logo-img { width: 100%; height: 100%; object-fit: cover; }
  .hero-logo-glow {
    position: absolute; inset: -20px; border-radius: 50%; z-index: 1;
    background: radial-gradient(circle, rgba(255,133,194,0.30), transparent 65%);
    filter: blur(12px);
    animation: logoPulse 3.5s ease-in-out infinite;
  }
  .hero-logo-pulse {
    position: absolute; inset: -6px; border-radius: 50%; z-index: 2;
    border: 1.5px solid rgba(255,133,194,0.30);
    animation: ringExpand 3.5s ease-in-out infinite;
  }
  @keyframes logoPulse {
    0%,100% { opacity: 0.6; transform: scale(0.92); }
    50%      { opacity: 1;   transform: scale(1.08); }
  }
  @keyframes ringExpand {
    0%,100% { transform: scale(0.95); opacity: 0.4; }
    50%      { transform: scale(1.12); opacity: 0; }
  }

  /* Заголовок */
  .hero-city-label {
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.24em;
    text-transform: uppercase; color: var(--rose-bright); margin: 0 0 8px;
    text-shadow: 0 0 16px rgba(255,133,194,0.50);
  }
  .hero-title {
    font-family: var(--font-script); font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 700; line-height: 1; margin: 0 0 10px;
    background: linear-gradient(135deg, var(--rose-bright) 0%, #FFD6EE 40%, var(--gold) 70%, var(--rose-deep) 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 30px rgba(255,133,194,0.30));
  }
  .hero-subtitle {
    color: var(--ink-soft); font-size: clamp(0.88rem, 2vw, 1rem);
    line-height: 1.7; max-width: 460px; margin: 0 0 16px;
  }
  .hero-meta { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
  .hero-rating { display: flex; align-items: center; gap: 6px; }
  .hero-stars { color: #FFD700; font-size: 0.82rem; letter-spacing: 2px; }
  .hero-rating-num {
    font-family: var(--font-display); font-size: 1.05rem; font-weight: 600;
    color: var(--gold);
  }
  .hero-reviews-link { color: var(--ink-mute); font-size: 0.82rem; }

  /* === БЛОК ФОТО + ОПИСАНИЕ === */
  .hero-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(20px, 4vw, 48px);
    align-items: center;
    position: relative; z-index: 2;
  }

  .hero-photo-slot { position: relative; }
  .hero-photo-inner {
    position: relative;
    border-radius: var(--r-lg);
    overflow: hidden;
    border: 1.5px solid rgba(255,133,194,0.25);
    box-shadow: 0 0 40px rgba(255,133,194,0.12), 0 24px 60px rgba(0,0,0,0.5);
    aspect-ratio: 4/5;
  }
  .hero-salon-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .hero-photo-inner:hover .hero-salon-img { transform: scale(1.03); }
  .hero-photo-badge {
    position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
    background: rgba(10,8,18,0.80); backdrop-filter: blur(12px);
    border: 1px solid rgba(255,133,194,0.30); border-radius: 999px;
    padding: 6px 18px; display: flex; align-items: center; gap: 7px;
    white-space: nowrap;
  }
  .badge-heart { color: var(--rose-bright); font-size: 0.9rem; }
  .badge-text { font-family: var(--font-script); font-size: 1rem; font-weight: 600; color: var(--ink); }

  .hero-photo-dot {
    position: absolute; border-radius: 50%;
    background: var(--rose-bright); opacity: 0.5;
    animation: dotPulse 3s ease-in-out infinite;
  }
  .hero-photo-dot-1 { width: 8px; height: 8px; top: -4px; right: 20px; }
  .hero-photo-dot-2 { width: 5px; height: 5px; bottom: 20px; right: -2px; animation-delay: 1.5s; }
  @keyframes dotPulse {
    0%,100% { opacity: 0.3; transform: scale(0.8); }
    50%      { opacity: 0.8; transform: scale(1.4); box-shadow: 0 0 12px var(--rose-bright); }
  }

  /* Описание */
  .hero-desc { position: relative; }
  .hero-desc-deco {
    font-size: 4rem; color: var(--rose-bright); opacity: 0.15;
    position: absolute; top: -20px; right: -10px; line-height: 1;
    text-shadow: 0 0 30px rgba(255,133,194,0.6);
    animation: hgFloat 6s ease-in-out infinite;
  }
  .hero-desc-title {
    font-family: var(--font-script); font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700; line-height: 1.2; margin: 0 0 16px;
    white-space: pre-line;
    background: linear-gradient(135deg, var(--ink) 0%, var(--rose-soft) 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-desc-text {
    color: var(--ink-soft); font-size: 0.95rem; line-height: 1.75;
    margin: 0 0 24px; max-width: 400px;
  }
  .hero-desc-stats {
    display: flex; align-items: center; gap: 0;
    background: rgba(255,133,194,0.05); border: 1px solid rgba(255,133,194,0.14);
    border-radius: var(--r-md); padding: 16px 20px; width: fit-content;
  }
  .hero-stat-item { text-align: center; padding: 0 18px; }
  .hero-stat-num {
    display: block; font-family: var(--font-script); font-size: 1.6rem; font-weight: 700;
    background: linear-gradient(135deg, var(--rose-bright), var(--gold));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; line-height: 1;
  }
  .hero-stat-label { font-size: 0.70rem; color: var(--ink-mute); letter-spacing: 0.10em; text-transform: uppercase; }
  .hero-stat-divider { width: 1px; height: 36px; background: rgba(255,133,194,0.15); flex-shrink: 0; }

  /* Hero rating link */
  .hero-rating { text-decoration: none; }
  .hero-stars { transition: text-shadow 0.3s ease; }
  .hero-rating:hover .hero-stars {
    text-shadow: 0 0 20px rgba(255,215,0,0.9), 0 0 40px rgba(255,215,0,0.5);
  }

  /* === RESPONSIVE === */
  @media (max-width: 820px) {
    /* Убираем верхний отступ — шапка теперь tall и показывает фото до кружка */
    .hero { padding-block-start: 20px; }
    .hero-top { grid-template-columns: 1fr; text-align: center; }
    .hero-logo-wrap { margin: 0 auto; }
    .hero-subtitle, .hero-meta { margin-inline: auto; }
    .hero-meta { justify-content: center; }
    .hero-body { grid-template-columns: 1fr; }
    .hero-photo-inner { aspect-ratio: 16/9; max-height: 260px; }
    .hero-desc-deco { display: none; }
    .hero-desc { text-align: center; }
    .hero-desc-stats { margin: 0 auto; }
    .hero-desc-text { margin-inline: auto; }
  }
  @media (max-width: 480px) {
    .hero-top { gap: 14px; }
    .hero-logo-ring { width: 88px; height: 88px; }
    .hero-title { font-size: 2.4rem; }
    .hero-stat-item { padding: 0 12px; }
  }
</style>

<script is:inline>
  (function() {
    var observed = false;
    function runCounters() {
      if (observed) return;
      observed = true;
      document.querySelectorAll('.hero-stat-num[data-count]').forEach(function(el) {
        var target = parseFloat(el.dataset.count);
        var suffix = el.dataset.suffix || '';
        var isFloat = String(target).includes('.');
        var duration = 1600;
        var start = null;
        function step(ts) {
          if (!start) start = ts;
          var prog = Math.min((ts - start) / duration, 1);
          var eased = 1 - Math.pow(1 - prog, 3);
          var val = target * eased;
          el.textContent = (isFloat ? val.toFixed(1) : Math.round(val)) + suffix;
          if (prog < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
    }
    var statsEl = document.querySelector('.hero-desc-stats');
    if (statsEl && 'IntersectionObserver' in window) {
      new IntersectionObserver(function(entries, obs) {
        if (entries[0].isIntersecting) { runCounters(); obs.disconnect(); }
      }, { threshold: 0.4 }).observe(statsEl);
    } else {
      runCounters();
    }
  })();
</script>
