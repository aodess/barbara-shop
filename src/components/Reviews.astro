---
import content from '../data/content.json';
import { t, pick } from '../lib/i18n.js';
const { lang } = Astro.props;
const tr = t(lang);
const review = content.googleReviews;
const fullStars = Math.floor(review.rating);
const hasHalf = review.rating % 1 >= 0.5;
---
<section class="reviews" id="reviews">
  <div class="reviews-glow"></div>
  <div class="container reviews-inner">
    <div class="reviews-content">
      <span class="eyebrow">{tr.reviews.eyebrow}</span>
      <h2>{tr.reviews.title}</h2>
      <p class="reviews-sub">{pick({ ru: 'Нам доверяют сотни клиентов в Бат-Яме и по всему Тель-Авивскому округу.', he: 'מאות לקוחות בבת ים ובמחוז תל אביב בוטחים בנו.', en: 'Hundreds of clients in Bat Yam and the Tel Aviv district trust us.' }, lang)}</p>

      <div class="rating-display">
        <div class="rating-big">
          <span class="rating-num text-gradient-gold">{review.rating}</span>
          <div class="rating-right">
            <div class="stars-row">
              {Array.from({ length: 5 }, (_, i) => (
                <svg class={`star-icon ${i < fullStars ? 'star-full' : (i === fullStars && hasHalf ? 'star-half' : 'star-empty')}`} viewBox="0 0 24 24" width="22" height="22">
                  <defs>
                    <linearGradient id={`sg${i}`} x1="0" x2="1" y1="0" y2="0">
                      <stop offset="50%" stop-color="currentColor"/>
                      <stop offset="50%" stop-color="transparent"/>
                    </linearGradient>
                  </defs>
                  {i < fullStars
                    ? <path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    : i === fullStars && hasHalf
                      ? <path fill={`url(#sg${i})`} d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      : <path fill="none" stroke="currentColor" stroke-width="1.5" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  }
                </svg>
              ))}
            </div>
            <span class="review-count">{review.count}+ {tr.reviews.rating}</span>
          </div>
        </div>

        <!-- Google badge -->
        <div class="google-badge">
          <svg class="google-logo" viewBox="0 0 24 24" width="22" height="22">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span>Google Reviews</span>
        </div>
      </div>

      {review.url && (
        <a class="btn btn-ghost reviews-link-btn" href={review.url} target="_blank" rel="noreferrer">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 8 16 12 12 16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
          {tr.reviews.link}
        </a>
      )}
    </div>

    <div class="reviews-visual">
      <div class="review-card-mock">
        <div class="rcm-header">
          <div class="rcm-avatar">B</div>
          <div>
            <p class="rcm-name">Barbara Shop</p>
            <div class="rcm-stars">
              {Array.from({ length: 5 }).map(() => (
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" style="color: var(--gold)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
          </div>
        </div>
        <p class="rcm-text">{pick({ ru: '«Лучший салон в Бат-Яме! Мастера — профессионалы высшего уровня. Результат превзошёл все ожидания.»', he: '«הסלון הטוב ביותר בבת ים! המעצבות מקצוענות ברמה הגבוהה ביותר. התוצאה עלתה על כל הציפיות.»', en: '«Best salon in Bat Yam! The stylists are top-level professionals. The result exceeded all expectations.»' }, lang)}</p>
        <div class="rcm-footer">
          <span class="rcm-source">via Google</span>
          <span class="rcm-date">{pick({ ru: 'недавно', he: 'לאחרונה', en: 'recently' }, lang)}</span>
        </div>
      </div>

      <div class="reviews-cert">
        <div class="cert-ring">
          <svg viewBox="0 0 120 120" fill="none" width="120" height="120">
            <circle cx="60" cy="60" r="54" stroke="url(#cg)" stroke-width="1" stroke-dasharray="5 10"/>
            <circle cx="60" cy="60" r="40" stroke="var(--gold)" stroke-width="0.5" opacity="0.3"/>
            <defs>
              <linearGradient id="cg" x1="0" y1="0" x2="120" y2="120" gradientUnits="userSpaceOnUse">
                <stop stop-color="#DDB87A"/>
                <stop offset="1" stop-color="#E090B4"/>
              </linearGradient>
            </defs>
          </svg>
          <div class="cert-inner">
            <span class="cert-num text-gradient-gold">{review.rating}</span>
            <span class="cert-label">★</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .reviews { position: relative; overflow: hidden; }
  .reviews-glow {
    position: absolute; top: 50%; right: -100px; transform: translateY(-50%);
    width: 500px; height: 400px;
    background: radial-gradient(ellipse, rgba(221,184,122,0.07), transparent 70%);
    pointer-events: none;
  }
  .reviews-inner {
    display: grid;
    grid-template-columns: minmax(0,1.2fr) minmax(280px,0.8fr);
    gap: 60px; align-items: center;
  }
  .reviews-content h2 { margin: 16px 0 16px; }
  .reviews-sub { color: var(--ink-soft); max-width: 500px; margin-bottom: 36px; }

  .rating-display { margin-bottom: 32px; display: flex; flex-direction: column; gap: 20px; }
  .rating-big { display: flex; align-items: center; gap: 20px; }
  .rating-num {
    font-family: var(--font-display); font-size: 5rem; font-weight: 300; line-height: 1;
    letter-spacing: -0.04em;
  }
  .rating-right { display: flex; flex-direction: column; gap: 8px; }
  .stars-row { display: flex; gap: 4px; }
  .star-icon.star-full { color: var(--gold); filter: drop-shadow(0 0 6px rgba(221,184,122,0.60)); }
  .star-icon.star-half { color: var(--gold); filter: drop-shadow(0 0 4px rgba(221,184,122,0.40)); }
  .star-icon.star-empty { color: rgba(221,184,122,0.25); }
  .review-count { font-size: 0.88rem; color: var(--ink-mute); }

  .google-badge {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 10px 18px; border-radius: 12px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);
    color: var(--ink-soft); font-size: 0.88rem; font-weight: 500;
    width: fit-content;
  }
  .reviews-link-btn { width: fit-content; }

  /* Right visual */
  .reviews-visual { display: grid; gap: 24px; }
  .review-card-mock {
    background: linear-gradient(145deg, var(--surface-raised) 0%, var(--surface-high) 100%);
    border: 1px solid rgba(221,184,122,0.16);
    border-radius: 24px; padding: 26px 24px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3), 0 0 60px rgba(221,184,122,0.06);
    position: relative;
  }
  .review-card-mock::before {
    content: '"';
    position: absolute; top: -8px; left: 20px;
    font-family: var(--font-display); font-size: 5rem; line-height: 1;
    color: var(--gold); opacity: 0.25;
  }
  .rcm-header { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
  .rcm-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--rose));
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 1.2rem; color: #fff; flex-shrink: 0;
  }
  .rcm-name { font-weight: 600; margin: 0 0 4px; font-size: 0.95rem; }
  .rcm-stars { display: flex; gap: 3px; }
  .rcm-text { font-size: 0.92rem; color: var(--ink-soft); line-height: 1.6; margin: 0 0 16px; font-style: italic; }
  .rcm-footer { display: flex; justify-content: space-between; font-size: 0.78rem; color: var(--ink-mute); }

  .reviews-cert { display: flex; justify-content: center; }
  .cert-ring { position: relative; width: 120px; height: 120px; display: flex; align-items: center; justify-content: center; }
  .cert-ring svg { position: absolute; inset: 0; animation: certRotate 20s linear infinite; }
  @keyframes certRotate { to { transform: rotate(360deg); } }
  .cert-inner { position: relative; z-index: 1; text-align: center; }
  .cert-num { font-family: var(--font-display); font-size: 2.2rem; display: block; line-height: 1; }
  .cert-label { font-size: 1.3rem; color: var(--gold); display: block; }

  @media (max-width: 860px) {
    .reviews-inner { grid-template-columns: 1fr; gap: 36px; }
    .reviews-visual { max-width: 440px; }
  }
</style>
